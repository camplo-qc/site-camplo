---
import '../styles/tokens.css';
import '../styles/base.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Camplo',
  description = "Camplo conçoit des sites de réservation et des logiciels de gestion pour les campings indépendants du Québec. Modernes, fiables, québécois.",
} = Astro.props;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=sentient@800,700,500&f[]=satoshi@700,500&f[]=general-sans@600,500&display=swap"
    />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_CA" />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
