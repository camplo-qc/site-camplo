---
import Layout from '../layouts/Layout.astro';

// Exploration de 3 templates pour la section Produits en split Site|CRM.
// Scroll pour comparer. Chaque template est autonome (ses propres styles).

const siteFeatures = [
  'Réservation en ligne',
  'Paiement par carte (Stripe)',
  'Confirmation automatique',
  'Aucune commission',
  'Mobile-first',
];

const crmFeatures = [
  'Tableau de bord',
  'Calendrier mensuel',
  'Réservations filtrables',
  'Emplacements + services',
  'Clients + historique',
  'Fiscalité TPS/TVQ',
  'Fonctionne hors-ligne',
];
---

<Layout>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Exploration · Split Produits</p>
      <h1>3 templates pour la section Site × CRM.</h1>
      <p class="lede">
        Chaque template propose une façon différente d'articuler les deux produits.
        Scroll pour comparer, choisis celui qui porte le message.
      </p>
    </header>

    {/* ═════════════════════════════════════════════════════════════════
        TEMPLATE 01 — ÉDITORIAL SPLIT
        Magazine spread. Typographie XXL, rail vertical au centre.
        ═════════════════════════════════════════════════════════════════ */}
    <section class="t1">
      <div class="t1-label">Template 01 · Éditorial Split</div>

      <div class="t1-grid">
        <div class="t1-side t1-left">
          <div class="t1-meta">
            <span class="t1-num">I.</span>
            <span class="t1-kicker">Pour vos campeurs</span>
          </div>
          <h2 class="t1-title">Le <em>site</em>.</h2>
          <p class="t1-body">
            Un site public qui fait une chose avec précision : transformer
            un visiteur curieux en réservation confirmée, paiement encaissé,
            courriel envoyé.
          </p>
          <ul class="t1-features">
            {siteFeatures.map((f) => <li>{f}</li>)}
          </ul>
          <div class="t1-shot t1-shot--site">
            <div class="t1-shot-placeholder">
              <span>Aperçu du site public</span>
            </div>
          </div>
        </div>

        <div class="t1-divider" aria-hidden="true"></div>

        <div class="t1-side t1-right">
          <div class="t1-meta">
            <span class="t1-num">II.</span>
            <span class="t1-kicker">Pour vous</span>
          </div>
          <h2 class="t1-title">Le <em>logiciel</em>.</h2>
          <p class="t1-body">
            Une app desktop Mac et Windows qui tourne localement.
            Calendrier, réservations, clients, emplacements, fiscalité.
            Pas de navigateur, pas de sync qui bloque.
          </p>
          <ul class="t1-features">
            {crmFeatures.map((f) => <li>{f}</li>)}
          </ul>
          <div class="t1-shot t1-shot--crm">
            <img src="/screenshots/crm-dashboard.png" alt="CRM · Tableau de bord" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    {/* ═════════════════════════════════════════════════════════════════
        TEMPLATE 02 — TABS INTERACTIVES
        Toggle Site|CRM avec slide animation entre les deux vues.
        ═════════════════════════════════════════════════════════════════ */}
    <section class="t2" aria-label="Template Tabs">
      <div class="t2-label">Template 02 · Tabs interactives</div>

      <div class="t2-head">
        <h2 class="t2-title">Un site. Un logiciel. <em>Deux faces.</em></h2>
        <div class="t2-tabs" role="tablist">
          <button
            type="button"
            role="tab"
            class="t2-tab is-active"
            data-target="t2-site"
            aria-selected="true"
          >
            <span class="t2-tab-num">01</span>
            <span class="t2-tab-label">Site</span>
          </button>
          <button
            type="button"
            role="tab"
            class="t2-tab"
            data-target="t2-crm"
            aria-selected="false"
          >
            <span class="t2-tab-num">02</span>
            <span class="t2-tab-label">CRM</span>
          </button>
        </div>
      </div>

      <div class="t2-stage">
        <div class="t2-panel is-active" id="t2-site" role="tabpanel">
          <div class="t2-copy">
            <p class="t2-kicker">Pour vos campeurs</p>
            <h3 class="t2-headline">Ils arrivent, ils réservent, <em>ils paient</em>.</h3>
            <p class="t2-sub">
              Pas de formulaire de 12 pages. Pas d'intermédiaire qui prend
              une commission. Juste un site qui convertit.
            </p>
            <ul class="t2-features">
              {siteFeatures.map((f) => <li>{f}</li>)}
            </ul>
          </div>
          <div class="t2-visual">
            <div class="t2-visual-placeholder">Aperçu du site public</div>
          </div>
        </div>

        <div class="t2-panel" id="t2-crm" role="tabpanel">
          <div class="t2-copy">
            <p class="t2-kicker">Pour vous</p>
            <h3 class="t2-headline">Votre camping, <em>sans le navigateur</em>.</h3>
            <p class="t2-sub">
              App desktop qui tourne sur votre Mac ou Windows. Vos
              données restent locales, sync quand la connexion revient.
            </p>
            <ul class="t2-features">
              {crmFeatures.map((f) => <li>{f}</li>)}
            </ul>
          </div>
          <div class="t2-visual">
            <img src="/screenshots/crm-calendrier.png" alt="CRM · Calendrier" />
          </div>
        </div>
      </div>
    </section>

    {/* ═════════════════════════════════════════════════════════════════
        TEMPLATE 03 — CARDS ASYMÉTRIQUES
        Deux grandes cards verticales côte à côte avec hover lift.
        ═════════════════════════════════════════════════════════════════ */}
    <section class="t3">
      <div class="t3-label">Template 03 · Cards asymétriques</div>

      <div class="t3-head">
        <p class="t3-eyebrow">01 · Produits</p>
        <h2 class="t3-title">Un site pour vos campeurs.<br /><em>Un logiciel pour vous.</em></h2>
      </div>

      <div class="t3-grid">
        <article class="t3-card t3-card--site">
          <div class="t3-card-top">
            <span class="t3-card-num">01</span>
            <span class="t3-card-tag">Web public</span>
          </div>

          <div class="t3-card-visual">
            <div class="t3-visual-placeholder">
              <span class="t3-visual-label">Aperçu site</span>
              <span class="t3-visual-url">delajoiequebec.com</span>
            </div>
          </div>

          <h3 class="t3-card-name">Le <em>site</em></h3>
          <p class="t3-card-desc">
            Vos campeurs réservent en ligne, paient par carte, reçoivent
            une confirmation. Aucune commission, aucun intermédiaire.
          </p>

          <ul class="t3-card-features">
            {siteFeatures.slice(0, 4).map((f) => <li>{f}</li>)}
          </ul>

          <div class="t3-card-foot">
            <span>En savoir plus</span>
            <span class="arrow">→</span>
          </div>
        </article>

        <article class="t3-card t3-card--crm">
          <div class="t3-card-top">
            <span class="t3-card-num">02</span>
            <span class="t3-card-tag">App desktop</span>
          </div>

          <div class="t3-card-visual t3-card-visual--crm">
            <img src="/screenshots/crm-dashboard.png" alt="CRM · Tableau de bord" loading="lazy" />
          </div>

          <h3 class="t3-card-name">Le <em>logiciel</em></h3>
          <p class="t3-card-desc">
            Mac et Windows. Calendrier, réservations, emplacements, clients,
            fiscalité. Fonctionne hors-ligne, sync automatique.
          </p>

          <ul class="t3-card-features">
            {crmFeatures.slice(0, 5).map((f) => <li>{f}</li>)}
          </ul>

          <div class="t3-card-foot">
            <span>En savoir plus</span>
            <span class="arrow">→</span>
          </div>
        </article>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  // T2 — Tabs toggle
  (() => {
    const tabs = document.querySelectorAll('.t2-tab');
    const panels = document.querySelectorAll('.t2-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        tabs.forEach((t) => {
          t.classList.toggle('is-active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        panels.forEach((p) => {
          p.classList.toggle('is-active', p.id === target);
        });
      });
    });
  })();
</script>

<style>
  /* ───── Page shell ───── */
  .page {
    padding-bottom: 120px;
  }

  .page-head {
    padding: clamp(48px, 8vw, 120px) var(--wrap-pad-x) clamp(32px, 5vw, 56px);
    max-width: 880px;
    margin: 0 auto;
  }
  .page-head .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
  }
  .page-head h1 {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5.5vw, 64px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .page-head .lede {
    margin-top: 18px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  /* Template label commun */
  .t1-label, .t2-label, .t3-label {
    display: inline-block;
    margin: 0 auto;
    padding: 6px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9999px;
  }

  /* ═══════════════════════════════════════════
     TEMPLATE 01 — ÉDITORIAL SPLIT
     ═══════════════════════════════════════════ */
  .t1 {
    background: var(--paper-warm);
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 120px);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .t1-label {
    display: block;
    margin: 0 auto clamp(48px, 6vw, 80px);
    width: fit-content;
  }

  .t1-grid {
    max-width: var(--wrap-max);
    margin: 0 auto;
    padding: 0 var(--wrap-pad-x);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: clamp(32px, 5vw, 80px);
  }
  .t1-divider {
    width: 1px;
    background: var(--rule);
  }

  .t1-side {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.5vw, 32px);
  }

  .t1-meta {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .t1-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(24px, 2.6vw, 36px);
    color: var(--marmalade);
    letter-spacing: -0.02em;
  }
  .t1-kicker {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }

  .t1-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 9vw, 120px);
    letter-spacing: -0.035em;
    line-height: 0.92;
    color: var(--ink);
  }
  .t1-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }

  .t1-body {
    margin: 0;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 40ch;
  }

  .t1-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 8px;
  }
  .t1-features li {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    padding-left: 18px;
    position: relative;
  }
  .t1-features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 10px;
    height: 1px;
    background: var(--marmalade);
  }

  .t1-shot {
    margin-top: clamp(16px, 2vw, 24px);
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper);
  }
  .t1-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .t1-shot-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    background: repeating-linear-gradient(
      45deg,
      var(--paper),
      var(--paper) 12px,
      var(--paper-warm) 12px,
      var(--paper-warm) 24px
    );
  }

  @media (max-width: 860px) {
    .t1-grid {
      grid-template-columns: 1fr;
    }
    .t1-divider {
      width: auto;
      height: 1px;
      margin: 24px 0;
    }
    .t1-title {
      font-size: clamp(44px, 11vw, 64px);
    }
  }

  /* ═══════════════════════════════════════════
     TEMPLATE 02 — TABS INTERACTIVES
     ═══════════════════════════════════════════ */
  .t2 {
    background: var(--paper);
    padding: clamp(64px, 8vw, 120px) var(--wrap-pad-x);
    border-bottom: 1px solid var(--rule);
  }
  .t2-label {
    display: block;
    margin: 0 auto clamp(40px, 5vw, 64px);
    width: fit-content;
  }

  .t2-head {
    max-width: var(--wrap-max);
    margin: 0 auto clamp(32px, 4vw, 56px);
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 40px;
    flex-wrap: wrap;
  }

  .t2-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 64px);
    letter-spacing: -0.025em;
    line-height: 1;
    max-width: 16ch;
  }
  .t2-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }

  .t2-tabs {
    display: inline-flex;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-radius: 9999px;
    padding: 4px;
    gap: 2px;
  }
  .t2-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: transparent;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 240ms ease, color 240ms ease;
  }
  .t2-tab-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    color: var(--marmalade);
  }
  .t2-tab.is-active {
    background: var(--ink);
    color: var(--paper);
  }
  .t2-tab.is-active .t2-tab-num {
    color: var(--marmalade);
  }

  .t2-stage {
    max-width: var(--wrap-max);
    margin: 0 auto;
    position: relative;
  }
  .t2-panel {
    display: none;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    animation: t2-fade 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .t2-panel.is-active {
    display: grid;
  }
  @keyframes t2-fade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .t2-kicker {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .t2-headline {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 3.5vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1.08;
  }
  .t2-headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }
  .t2-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 42ch;
  }
  .t2-features {
    list-style: none;
    margin-top: 24px;
    padding: 0;
    display: grid;
    gap: 8px;
    grid-template-columns: 1fr 1fr;
  }
  .t2-features li {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    padding-left: 16px;
    position: relative;
  }
  .t2-features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 8px;
    height: 1px;
    background: var(--marmalade);
  }

  .t2-visual {
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper-warm);
  }
  .t2-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .t2-visual-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    background: repeating-linear-gradient(
      45deg,
      var(--paper),
      var(--paper) 12px,
      var(--paper-warm) 12px,
      var(--paper-warm) 24px
    );
  }

  @media (max-width: 860px) {
    .t2-panel.is-active {
      grid-template-columns: 1fr;
    }
    .t2-head {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* ═══════════════════════════════════════════
     TEMPLATE 03 — CARDS ASYMÉTRIQUES
     ═══════════════════════════════════════════ */
  .t3 {
    background: var(--paper-warm);
    padding: clamp(64px, 8vw, 120px) var(--wrap-pad-x) clamp(72px, 9vw, 128px);
  }
  .t3-label {
    display: block;
    margin: 0 auto clamp(40px, 5vw, 64px);
    width: fit-content;
  }

  .t3-head {
    max-width: 720px;
    margin: 0 auto clamp(48px, 6vw, 80px);
    text-align: center;
  }
  .t3-eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .t3-title {
    margin: 16px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .t3-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }

  .t3-grid {
    max-width: var(--wrap-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 2.5vw, 32px);
  }

  .t3-card {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 2.2vw, 28px);
    padding: clamp(28px, 3.2vw, 44px);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 6px;
    cursor: default;
    transition: transform 480ms cubic-bezier(0.22, 1, 0.36, 1), border-color 320ms ease;
  }
  .t3-card:hover {
    transform: translateY(-6px);
    border-color: var(--fern);
  }

  .t3-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
  }
  .t3-card-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(24px, 2.4vw, 32px);
    color: var(--marmalade);
    letter-spacing: -0.02em;
  }
  .t3-card-tag {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fern);
    padding: 5px 10px;
    border: 1px solid var(--rule);
    border-radius: 9999px;
  }

  .t3-card-visual {
    aspect-ratio: 16 / 10;
    border-radius: 4px;
    overflow: hidden;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
  }
  .t3-card-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .t3-visual-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: repeating-linear-gradient(
      45deg,
      var(--paper),
      var(--paper) 12px,
      var(--paper-warm) 12px,
      var(--paper-warm) 24px
    );
  }
  .t3-visual-label {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: 18px;
  }
  .t3-visual-url {
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--marmalade);
