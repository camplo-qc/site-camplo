---
import Layout from '../layouts/Layout.astro';

// Exploration : section 04 en mode minimaliste. Juste un label
// "Notre logiciel est présent dans" + le(s) logo(s). Sans eyebrow, sans titre,
// sans section-note. 5 variations de structure.
---

<Layout>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Exploration · Présence minimaliste</p>
      <h1>5 façons d'afficher « Notre logiciel est présent dans ».</h1>
      <p class="lede">
        Sans eyebrow, sans titre-section, sans note — juste un label
        discret et le logo. Différentes mises en page à comparer.
      </p>
    </header>

    {/* ══════════════════════════════════════════════════════════════════
        V1 — CENTRÉ MINIMAL (label sm + logo stacké en dessous)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v1">
      <div class="demo-label">V1 · Centré minimal</div>
      <div class="v1-box">
        <p class="v1-kicker">Notre logiciel est présent dans</p>
        <a class="v1-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V2 — HAIRLINES (rule top + bottom, label + logo en row)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v2">
      <div class="demo-label">V2 · Hairlines horizontales</div>
      <div class="v2-box">
        <p class="v2-kicker">Notre logiciel est présent dans</p>
        <div class="v2-row">
          <a class="v2-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
            <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
          </a>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V3 — INLINE SIMPLE (tout sur une ligne, label + logo)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v3">
      <div class="demo-label">V3 · Inline simple</div>
      <div class="v3-box">
        <span class="v3-kicker">Notre logiciel est présent dans</span>
        <a class="v3-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V4 — RIBBON PLEIN (fond paper-warm, pleine largeur, label gauche + logo droite)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v4">
      <div class="demo-label">V4 · Ribbon pleine largeur</div>
      <div class="v4-wrap">
        <div class="v4-ribbon">
          <span class="v4-kicker">Notre logiciel est présent dans —</span>
          <a class="v4-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
            <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
          </a>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V5 — LOGO WALL STYLE PRESSE (label centré, logo(s) dessous en grid)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v5">
      <div class="demo-label">V5 · Logo wall style presse</div>
      <div class="v5-box">
        <p class="v5-kicker">
          <span class="v5-rule" aria-hidden="true"></span>
          Notre logiciel est présent dans
          <span class="v5-rule" aria-hidden="true"></span>
        </p>
        <div class="v5-logos">
          <a class="v5-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
            <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ───── Page shell ───── */
  .page {
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 120px);
  }
  .page-head {
    max-width: 880px;
    margin: 0 auto clamp(56px, 7vw, 96px);
    padding: 0 var(--wrap-pad-x);
  }
  .page-head .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
    margin: 0;
  }
  .page-head h1 {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .page-head .lede {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 54ch;
  }

  /* ───── Demo wrappers ───── */
  .demo {
    margin-bottom: clamp(56px, 7vw, 88px);
    padding: 0 var(--wrap-pad-x);
  }
  .demo-label {
    display: inline-block;
    padding: 6px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9999px;
    margin-bottom: 28px;
  }

  /* Kicker commun */
  .v1-kicker, .v2-kicker, .v3-kicker, .v4-kicker, .v5-kicker {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
  }

  /* Client link hover behavior commun */
  a[class*="-client"] {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1), opacity 240ms ease;
  }
  a[class*="-client"]:hover {
    transform: translateY(-2px);
    opacity: 0.88;
  }
  a[class*="-client"] img {
    display: block;
    width: auto;
  }

  /* ═══════════════════════════════════════════
     V1 — CENTRÉ MINIMAL
     ═══════════════════════════════════════════ */
  .v1-box {
    background: var(--paper);
    padding: clamp(48px, 6vw, 80px) clamp(24px, 3vw, 48px);
    text-align: center;
  }
  .v1-kicker {
    margin: 0 0 28px;
  }
  .v1-client img {
    height: clamp(80px, 9vw, 112px);
  }

  /* ═══════════════════════════════════════════
     V2 — HAIRLINES HORIZONTALES
     ═══════════════════════════════════════════ */
  .v2-box {
    background: var(--paper);
    padding: clamp(36px, 4vw, 56px) clamp(24px, 3vw, 48px);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .v2-kicker {
    text-align: center;
    display: block;
    margin: 0 0 24px;
  }
  .v2-row {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .v2-client img {
    height: clamp(80px, 9vw, 112px);
  }

  /* ═══════════════════════════════════════════
     V3 — INLINE SIMPLE
     ═══════════════════════════════════════════ */
  .v3-box {
    padding: clamp(32px, 4vw, 56px) 0;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .v3-client img {
    height: clamp(44px, 4.5vw, 56px);
  }

  /* ═══════════════════════════════════════════
     V4 — RIBBON PLEINE LARGEUR
     ═══════════════════════════════════════════ */
  .v4-wrap {
    /* break-out to full width within the page's padding */
    margin: 0 calc(-1 * var(--wrap-pad-x));
  }
  .v4-ribbon {
    background: var(--paper-warm);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: clamp(20px, 2.5vw, 32px) var(--wrap-pad-x);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(16px, 2vw, 28px);
    flex-wrap: wrap;
  }
  .v4-kicker {
    white-space: nowrap;
  }
  .v4-client img {
    height: clamp(48px, 5vw, 64px);
  }

  /* ═══════════════════════════════════════════
     V5 — LOGO WALL STYLE PRESSE
     ═══════════════════════════════════════════ */
  .v5-box {
    padding: clamp(40px, 5vw, 72px) clamp(24px, 3vw, 48px);
    text-align: center;
  }
  .v5-kicker {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin: 0 0 32px;
  }
  .v5-rule {
    width: clamp(32px, 6vw, 72px);
    height: 1px;
    background: var(--marmalade);
  }
  .v5-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: clamp(32px, 5vw, 64px);
    flex-wrap: wrap;
  }
  .v5-client img {
    height: clamp(72px, 8vw, 96px);
  }
</style>
