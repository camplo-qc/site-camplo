---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import CeQuOnFait from '../components/CeQuOnFait.astro';
import Faq from '../components/Faq.astro';
import CtaFinal from '../components/CtaFinal.astro';
import PresentDans from '../components/PresentDans.astro';
import Footer from '../components/Footer.astro';
import { crmSoftwareApplication, siteSoftwareApplication } from '../data/schema';

// La home présente les 2 produits → injecte les 2 SoftwareApplication.
const pageJsonLd = [crmSoftwareApplication, siteSoftwareApplication];
---

<Layout pageJsonLd={pageJsonLd}>
  <Nav />
  <main id="top">
    <Hero />
    <CeQuOnFait />
    <Faq />
    <CtaFinal />
    <PresentDans />
  </main>
  <Footer />
</Layout>
