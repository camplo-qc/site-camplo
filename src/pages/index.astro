---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Diagnostic from '../components/Diagnostic.astro';
import ProductsIntro from '../components/ProductsIntro.astro';
import CrmShowcase from '../components/CrmShowcase.astro';
import SitePublic from '../components/SitePublic.astro';
import CaseStudy from '../components/CaseStudy.astro';
import Process from '../components/Process.astro';
import Qualify from '../components/Qualify.astro';
import Faq from '../components/Faq.astro';
import CtaFinal from '../components/CtaFinal.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main id="top">
    <Hero />
    <Diagnostic />
    <ProductsIntro />
    <CrmShowcase />
    <SitePublic />
    <CaseStudy />
    <Process />
    <Qualify />
    <Faq />
    <CtaFinal />
  </main>
  <Footer />
</Layout>
