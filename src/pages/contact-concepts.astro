---
import Layout from '../layouts/Layout.astro';

const EMAIL = 'adamauger872@gmail.com';
const PHONE = '5817480161';
const PHONE_DISPLAY = '581 748-0161';
---

<Layout>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Exploration · Section Contact</p>
      <h1>5 directions pour la refonte de la section Contact.</h1>
      <p class="lede">
        Actuellement : deux tiles (courriel + téléphone) avec titre et
        signal. Voici 5 angles plus distincts — du minimaliste pur au
        split asymétrique, en passant par une approche conversationnelle.
      </p>
    </header>

    {/* ══════════════════════════════════════════════════════════════════
        V1 — ULTRA MINIMAL (courriel en XXL, point final)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v1">
      <div class="demo-label">V1 · Ultra minimal</div>
      <div class="v1-block">
        <p class="v1-pitch">
          Une question ? Un devis ?
          <em>Écrivez-nous.</em>
        </p>
        <a class="v1-mail" href={`mailto:${EMAIL}`}>
          {EMAIL}
          <span class="v1-arrow" aria-hidden="true">↗</span>
        </a>
        <p class="v1-meta">Réponse en moins de 48h · <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></p>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V2 — BIG CTA PILL (un seul bouton proéminent)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v2">
      <div class="demo-label">V2 · Big CTA pill</div>
      <div class="v2-block">
        <p class="v2-kicker">Contact</p>
        <h2 class="v2-title">
          Vous avez un camping.<br />
          <em>On a un outil.</em>
        </h2>
        <p class="v2-sub">
          Un courriel, une discussion de 25 minutes. Si on peut vous
          aider, on le dit. Sinon aussi.
        </p>
        <a class="v2-cta" href={`mailto:${EMAIL}`}>
          <span>Commencer une conversation</span>
          <span class="v2-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </span>
        </a>
        <p class="v2-fallback">Vous préférez parler ? <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></p>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V3 — SPLIT ASYMÉTRIQUE (copy à gauche, actions à droite)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v3">
      <div class="demo-label">V3 · Split asymétrique</div>
      <div class="v3-block">
        <div class="v3-left">
          <p class="v3-kicker">05 · Contact</p>
          <h2 class="v3-title">On parle <em>quand</em> ?</h2>
          <p class="v3-note">
            Écrivez ou appelez. On répond sous 48h ouvrables.
            Jamais de deuxième appel de vente pressé.
          </p>
        </div>
        <div class="v3-right">
          <a class="v3-action" href={`mailto:${EMAIL}`}>
            <span class="v3-action-label">Courriel</span>
            <span class="v3-action-value">{EMAIL}</span>
            <span class="v3-arrow" aria-hidden="true">↗</span>
          </a>
          <a class="v3-action" href={`tel:${PHONE}`}>
            <span class="v3-action-label">Téléphone</span>
            <span class="v3-action-value">{PHONE_DISPLAY}</span>
            <span class="v3-arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V4 — CONVERSATION / CHAT BUBBLE
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v4">
      <div class="demo-label">V4 · Conversation</div>
      <div class="v4-block">
        <div class="v4-thread">
          <div class="v4-bubble v4-them">
            <span class="v4-who">Vous</span>
            <p>Est-ce que Camplo marcherait pour mon camping ?</p>
          </div>
          <div class="v4-bubble v4-us">
            <span class="v4-who">Camplo</span>
            <p>
              Écrivez-nous à
              <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
              ou appelez au <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a>.
              On répond sous 48h.
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V5 — DARK PANEL (fond ink contrasté, CTA marmalade)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="demo v5">
      <div class="demo-label">V5 · Dark panel</div>
      <div class="v5-block">
        <div class="v5-left">
          <p class="v5-kicker">Contact</p>
          <h2 class="v5-title">Prêt à <em>parler</em> ?</h2>
          <p class="v5-note">
            Un courriel, un appel. Réponse sous 48h, toujours.
          </p>
        </div>
        <div class="v5-right">
          <a class="v5-primary" href={`mailto:${EMAIL}`}>
            <span>Écrivez-nous</span>
            <span class="v5-arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          </a>
          <a class="v5-secondary" href={`tel:${PHONE}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.84.57 2.8.7A2 2 0 0 1 22 16.92z" />
            </svg>
            {PHONE_DISPLAY}
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ───── Page shell ───── */
  .page {
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 120px);
  }
  .page-head {
    max-width: 880px;
    margin: 0 auto clamp(56px, 7vw, 96px);
    padding: 0 var(--wrap-pad-x);
  }
  .page-head .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
    margin: 0;
  }
  .page-head h1 {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .page-head .lede {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 54ch;
  }

  .demo {
    margin-bottom: clamp(48px, 6vw, 80px);
    padding: 0 var(--wrap-pad-x);
  }
  .demo-label {
    display: inline-block;
    padding: 6px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9999px;
    margin-bottom: 24px;
  }

  /* ═══════════════════════════════════════════
     V1 — ULTRA MINIMAL
     ═══════════════════════════════════════════ */
  .v1-block {
    background: var(--paper);
    padding: clamp(56px, 8vw, 120px) clamp(24px, 3vw, 48px);
    text-align: center;
  }
  .v1-pitch {
    margin: 0 0 clamp(32px, 4vw, 48px);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--ink-soft);
    line-height: 1.3;
  }
  .v1-pitch em {
    color: var(--ink);
    font-style: italic;
  }
  .v1-mail {
    display: inline-flex;
    align-items: baseline;
    gap: 14px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 5vw, 64px);
    letter-spacing: -0.025em;
    color: var(--fern);
    text-decoration: none;
    border-bottom: 2px solid var(--marmalade);
    padding-bottom: 6px;
    transition: color 240ms ease;
    word-break: break-word;
  }
  .v1-mail:hover { color: var(--marmalade); }
  .v1-arrow {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--marmalade);
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .v1-mail:hover .v1-arrow {
    transform: translate(6px, -6px);
  }
  .v1-meta {
    margin: clamp(24px, 3vw, 32px) 0 0;
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .v1-meta a {
    color: var(--fern);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 240ms ease;
  }
  .v1-meta a:hover { color: var(--marmalade); }

  /* ═══════════════════════════════════════════
     V2 — BIG CTA PILL
     ═══════════════════════════════════════════ */
  .v2-block {
    background: var(--paper-warm);
    padding: clamp(56px, 7vw, 96px) clamp(24px, 3vw, 48px);
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }
  .v2-kicker {
    margin: 0 0 16px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .v2-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5.5vw, 72px);
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
  }
  .v2-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }
  .v2-sub {
    margin: clamp(20px, 2.4vw, 28px) auto 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(17px, 1.4vw, 20px);
    color: var(--ink-soft);
    max-width: 38ch;
    line-height: 1.5;
  }
  .v2-cta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: clamp(32px, 4vw, 48px);
    padding: 20px 32px;
    background: var(--marmalade);
    color: var(--paper);
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: background-color 240ms ease, transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-cta:hover {
    background: var(--fern);
    transform: translateY(-2px);
  }
  .v2-arrow {
    display: inline-flex;
    width: 20px;
    height: 20px;
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v2-arrow svg { width: 100%; height: 100%; }
  .v2-cta:hover .v2-arrow {
    transform: translateX(4px);
  }
  .v2-fallback {
    margin: clamp(20px, 2.4vw, 28px) 0 0;
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .v2-fallback a {
    color: var(--fern);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
  }

  /* ═══════════════════════════════════════════
     V3 — SPLIT ASYMÉTRIQUE
     ═══════════════════════════════════════════ */
  .v3-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    padding: clamp(48px, 6vw, 80px) clamp(24px, 3vw, 48px);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .v3-kicker {
    margin: 0 0 16px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .v3-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 72px);
    letter-spacing: -0.025em;
    line-height: 1;
  }
  .v3-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }
  .v3-note {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-soft);
    max-width: 34ch;
    line-height: 1.5;
  }
  .v3-right {
    display: grid;
    gap: 14px;
  }
  .v3-action {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 16px;
    align-items: baseline;
    padding: 20px 24px;
    background: var(--paper-warm);
    border: 1px solid var(--rule);
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    transition: background-color 240ms ease, border-color 240ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v3-action:hover {
    background: var(--paper);
    border-color: var(--fern);
    transform: translateX(3px);
  }
  .v3-action-label {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .v3-action-value {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    color: var(--ink);
  }
  .v3-arrow {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--marmalade);
    font-size: 16px;
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .v3-action:hover .v3-arrow {
    transform: translate(4px, -4px);
  }
  @media (max-width: 720px) {
    .v3-block {
      grid-template-columns: 1fr;
    }
  }

  /* ═══════════════════════════════════════════
     V4 — CONVERSATION / CHAT BUBBLE
     ═══════════════════════════════════════════ */
  .v4-block {
    padding: clamp(48px, 6vw, 80px) clamp(24px, 3vw, 48px);
    max-width: 680px;
    margin: 0 auto;
  }
  .v4-thread {
    display: grid;
    gap: 20px;
  }
  .v4-bubble {
    padding: 18px 24px;
    border-radius: 20px;
    max-width: 82%;
  }
  .v4-bubble p {
    margin: 8px 0 0;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.2vw, 17px);
    line-height: 1.55;
  }
  .v4-who {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .v4-them {
    background: var(--paper-warm);
    border-top-left-radius: 4px;
    color: var(--ink);
  }
  .v4-us {
    background: var(--ink);
    color: var(--paper);
    margin-left: auto;
    border-top-right-radius: 4px;
  }
  .v4-us a {
    color: var(--marmalade);
    text-decoration: none;
    border-bottom: 1px dashed var(--marmalade);
    padding-bottom: 1px;
    transition: color 240ms ease;
  }
  .v4-us a:hover { color: var(--paper); }

  /* ═══════════════════════════════════════════
     V5 — DARK PANEL
     ═══════════════════════════════════════════ */
  .v5-block {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(48px, 6vw, 88px) clamp(32px, 4vw, 64px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    border-radius: 6px;
  }
  .v5-kicker {
    margin: 0 0 16px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--marmalade);
  }
  .v5-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5.5vw, 80px);
    letter-spacing: -0.025em;
    line-height: 0.95;
    color: var(--paper);
  }
  .v5-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }
  .v5-note {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--paper-warm);
    opacity: 0.8;
    line-height: 1.5;
    max-width: 32ch;
  }
  .v5-right {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: flex-start;
  }
  .v5-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 18px 28px;
    background: var(--marmalade);
    color: var(--paper);
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: background-color 240ms ease, transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v5-primary:hover {
    background: var(--paper);
    color: var(--ink);
    transform: translateY(-2px);
  }
  .v5-arrow {
    display: inline-flex;
    width: 18px;
    height: 18px;
  }
  .v5-arrow svg { width: 100%; height: 100%; }
  .v5-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    color: var(--paper-warm);
    text-decoration: none;
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid rgba(246, 240, 224, 0.2);
    border-radius: 9999px;
    transition: border-color 240ms ease, color 240ms ease;
  }
  .v5-secondary svg {
    width: 14px;
    height: 14px;
  }
  .v5-secondary:hover {
    border-color: var(--paper);
    color: var(--paper);
  }
  @media (max-width: 720px) {
    .v5-block {
      grid-template-columns: 1fr;
    }
  }
</style>
