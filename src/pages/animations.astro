---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';

const svgRaw = fs.readFileSync(
  path.resolve('public/brand/camplo-wordmark.svg'),
  'utf-8'
);

// Injecte des classes : lettres+C+mplo = .cm-word, arbre = .cm-tree, tente = .cm-tent
const svg = svgRaw
  .replace('<g fill="#3E6B31">', '<g class="cm-word" fill="#3E6B31">')
  .replace('<path d="M 29.25 3', '<path class="cm-tree" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent" d="M 29.5 27');

// Version stagger : wrap chaque lettre dans un <g> externe pour ne pas
// écraser le transform="translate(x,0) scale(1,-1)" inline qui positionne
let i = 0;
const svgStagger2 = svgRaw
  .replace(
    /<g transform="translate\([^)]+\) scale\(1,-1\)"><path[^/]+\/><\/g>/g,
    (match) => {
      const idx = i++;
      return `<g class="cm-letter cm-l${idx}">${match}</g>`;
    }
  )
  .replace('<path d="M 29.25 3', '<path class="cm-tree-s" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent-s" d="M 29.5 27');

// Version 3: ambient (pas de reveal, mais sway permanent)
const svgAmbient = svgRaw
  .replace('<path d="M 29.25 3', '<path class="cm-tree-a" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent-a" d="M 29.5 27');

// Version 4 (wipe): classe générique sur tout
const svgWipe = svgRaw;

// Version 5 (tree grows from seed): classes pour arbre, tente, lettres globales
const svgGrow = svgRaw
  .replace('<g fill="#3E6B31">', '<g class="cm-word-g" fill="#3E6B31">')
  .replace('<path d="M 29.25 3', '<path class="cm-tree-g" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent-g" d="M 29.5 27');

// Version 6 (letter flip 3D): wrap chaque lettre dans un <g> externe
let j = 0;
const svgFlip = svgRaw
  .replace(
    /<g transform="translate\([^)]+\) scale\(1,-1\)"><path[^/]+\/><\/g>/g,
    (match) => {
      const idx = j++;
      return `<g class="cm-flip cm-f${idx}">${match}</g>`;
    }
  )
  .replace('<path d="M 29.25 3', '<path class="cm-tree-f" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent-f" d="M 29.5 27');

// Restructure: arbre hors de la clipPath (pas de notch dans l'arbre), tente dans
// la clipPath, + insertion d'un path beige (paper) à l'emplacement de la fente
// pour couvrir l'arbre qui apparaîtrait à travers le cut. Le path "cm-door"
// s'anime avec la tente.
// Door coords sont dans le mark space (pas le translate(3,0) interne), donc
// on dessine le path beige sans translate.
const DOOR_PATH =
  '<path class="cm-door" d="M 32.5 40 L 33.5 40 L 36 54.5 L 30 54.5 Z" fill="#F6F0E0"/>';
// Wrap tente + fente dans un seul groupe "cm-tent-move" pour qu'ils s'animent
// comme une seule unité (même transform-origin, même transform).
const splitClip = (s) =>
  s.replace(
    /<g clip-path="url\(#door\)">\s*<g transform="translate\(3, 0\)">\s*(<path[^>]*tree[^>]*\/>)\s*(<path[^>]*tent[^>]*\/>)\s*<\/g>\s*<\/g>/,
    (_, tree, tent) =>
      `<g transform="translate(3, 0)">${tree}</g>` +
      `<g class="cm-tent-move">` +
      `${DOOR_PATH}` +
      `<g clip-path="url(#door)"><g transform="translate(3, 0)">${tent}</g></g>` +
      `</g>`
  );

const svgFixed = splitClip(svg);
const svgStaggerFixed = splitClip(svgStagger2);
const svgGrowFixed = splitClip(svgGrow);
const svgFlipFixed = splitClip(svgFlip);
---

<Layout title="Camplo · Animations hero">
  <main>
    <header class="page-head">
      <p class="eyebrow">Démo · animations hero</p>
      <h1>Trois pistes.</h1>
      <p class="lede">Chaque démo rejoue au clic. Aucune n'est pushée en prod pour le moment.</p>
    </header>

    <!-- DEMO 1 — Tente pop from behind tree -->
    <section class="demo" data-demo="pop">
      <div class="demo-head">
        <div>
          <p class="num">01</p>
          <h2>Tente qui pop depuis derrière l'arbre</h2>
          <p class="desc">Le wordmark apparaît d'abord (C, arbre, mplo). La tente surgit ensuite depuis sous l'arbre avec un léger overshoot.</p>
        </div>
        <button class="replay" type="button">Rejouer</button>
      </div>
      <div class="stage stage-pop">
        <div class="svg-wrap" set:html={svgFixed} />
      </div>
    </section>

    <!-- DEMO 2 — Stagger letter-by-letter -->
    <section class="demo" data-demo="stagger">
      <div class="demo-head">
        <div>
          <p class="num">02</p>
          <h2>Stagger lettre par lettre</h2>
          <p class="desc">Chaque lettre apparaît une à une, l'arbre ensuite, la tente en dernier. Rythme éditorial.</p>
        </div>
        <button class="replay" type="button">Rejouer</button>
      </div>
      <div class="stage stage-stagger">
        <div class="svg-wrap" set:html={svgStaggerFixed} />
      </div>
    </section>

    <!-- DEMO 3 — Ambient -->
    <section class="demo" data-demo="ambient">
      <div class="demo-head">
        <div>
          <p class="num">03</p>
          <h2>Ambient — arbre qui sway, tente qui respire</h2>
          <p class="desc">Aucun reveal à l'entrée. Mouvement permanent subtil : l'arbre oscille très doucement, la tente a un léger pulse.</p>
        </div>
        <span class="note">(boucle — rien à rejouer)</span>
      </div>
      <div class="stage stage-ambient">
        <div class="svg-wrap" set:html={svgAmbient} />
      </div>
    </section>

    <!-- DEMO 4 — Wipe L→R -->
    <section class="demo" data-demo="wipe">
      <div class="demo-head">
        <div>
          <p class="num">04</p>
          <h2>Wipe gauche → droite</h2>
          <p class="desc">Le wordmark est révélé par une balayage horizontal, comme un coup de pinceau. Net, punchy, confiant.</p>
        </div>
        <button class="replay" type="button">Rejouer</button>
      </div>
      <div class="stage stage-wipe">
        <div class="svg-wrap" set:html={svgWipe} />
      </div>
    </section>

    <!-- DEMO 5 — Tree grows -->
    <section class="demo" data-demo="grow">
      <div class="demo-head">
        <div>
          <p class="num">05</p>
          <h2>L'arbre pousse depuis la baseline</h2>
          <p class="desc">L'arbre sort du sol (scale Y depuis 0), les lettres apparaissent autour, la tente se plante en dernier. Thématique camping, narratif.</p>
        </div>
        <button class="replay" type="button">Rejouer</button>
      </div>
      <div class="stage stage-grow">
        <div class="svg-wrap" set:html={svgGrowFixed} />
      </div>
    </section>

    <!-- DEMO 6 — Letter 3D flip -->
    <section class="demo" data-demo="flip">
      <div class="demo-head">
        <div>
          <p class="num">06</p>
          <h2>Flip 3D des lettres</h2>
          <p class="desc">Chaque lettre pivote sur son axe Y depuis 90°, comme un panneau qui se retourne. Arbre + tente suivent.</p>
        </div>
        <button class="replay" type="button">Rejouer</button>
      </div>
      <div class="stage stage-flip">
        <div class="svg-wrap" set:html={svgFlipFixed} />
      </div>
    </section>
  </main>

  <script is:inline>
    document.querySelectorAll('.demo .replay').forEach((btn) => {
      btn.addEventListener('click', () => {
        const stage = btn.closest('.demo').querySelector('.stage');
        stage.classList.remove('play');
        // force reflow so animation restarts
        void stage.offsetWidth;
        stage.classList.add('play');
      });
    });
    // auto-play on load
    document.querySelectorAll('.stage-pop, .stage-stagger, .stage-wipe, .stage-grow, .stage-flip').forEach((s) => {
      s.classList.add('play');
    });
  </script>

  <style>
    main {
      background: var(--paper);
      padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 120px);
    }

    .page-head {
      max-width: var(--wrap-max);
      margin: 0 auto;
      padding: 0 var(--wrap-pad-x);
    }
    .eyebrow {
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--fern);
    }
    .page-head h1 {
      margin-top: 12px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(32px, 4vw, 52px);
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--ink);
    }
    .lede {
      margin-top: 14px;
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      color: var(--ink-soft);
      max-width: 56ch;
    }

    .demo {
      max-width: var(--wrap-max);
      margin: clamp(48px, 6vw, 80px) auto 0;
      padding: 0 var(--wrap-pad-x);
    }

    .demo-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      flex-wrap: wrap;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--rule);
    }
    .num {
      font-family: var(--font-display);
      font-style: italic;
      font-weight: 500;
      color: var(--marmalade);
      font-size: 16px;
    }
    .demo-head h2 {
      margin-top: 4px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(22px, 2.4vw, 30px);
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: var(--ink);
    }
    .desc {
      margin-top: 8px;
      font-family: var(--font-body);
      font-size: 15px;
      line-height: 1.55;
      color: var(--ink-soft);
      max-width: 62ch;
    }
    .replay {
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: var(--ink);
      color: var(--paper);
      padding: 10px 18px;
      border-radius: 9999px;
      transition: background 160ms ease;
      flex-shrink: 0;
    }
    .replay:hover {
      background: var(--marmalade);
    }
    .note {
      font-family: var(--font-label);
      font-size: 12px;
      color: var(--ink-muted);
      font-style: italic;
    }

    .stage {
      margin-top: clamp(32px, 4vw, 48px);
      background: var(--paper);
      padding: clamp(24px, 3vw, 48px) 0;
      display: flex;
      justify-content: center;
    }
    .svg-wrap {
      width: 100%;
      max-width: 720px;
    }
    .svg-wrap :global(svg) {
      display: block;
      width: 100%;
      height: auto;
      overflow: visible;
    }

    /* ───── DEMO 1 : POP FROM BEHIND ───── */
    .stage-pop .svg-wrap :global(.cm-word),
    .stage-pop .svg-wrap :global(.cm-tree) {
      opacity: 0;
    }
    .stage-pop .svg-wrap :global(.cm-tent-move) {
      opacity: 0;
      transform-box: fill-box;
      transform-origin: 50% 100%;
      transform: translateY(22px) scaleY(0.3);
    }
    .stage-pop.play .svg-wrap :global(.cm-word),
    .stage-pop.play .svg-wrap :global(.cm-tree) {
      animation: pop-word 720ms cubic-bezier(0.2, 0.7, 0.1, 1) 120ms forwards;
    }
    .stage-pop.play .svg-wrap :global(.cm-tent-move) {
      animation: pop-tent 560ms cubic-bezier(0.2, 1.3, 0.4, 1) 620ms forwards;
    }
    @keyframes pop-word {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes pop-tent {
      0%   { opacity: 0; transform: translateY(22px) scaleY(0.3); }
      60%  { opacity: 1; }
      100% { opacity: 1; transform: translateY(0) scaleY(1); }
    }

    /* ───── DEMO 2 : STAGGER ───── */
    .stage-stagger .svg-wrap :global(.cm-letter),
    .stage-stagger .svg-wrap :global(.cm-tree-s),
    .stage-stagger .svg-wrap :global(.cm-tent-move) {
      opacity: 0;
    }
    .stage-stagger .svg-wrap :global(.cm-tent-move) {
      transform-box: fill-box;
      transform-origin: 50% 100%;
    }
    .stage-stagger.play .svg-wrap :global(.cm-letter),
    .stage-stagger.play .svg-wrap :global(.cm-tree-s),
    .stage-stagger.play .svg-wrap :global(.cm-tent-s) {
      animation: stag-in 520ms cubic-bezier(0.2, 0.7, 0.1, 1) forwards;
    }
    /* Ordre visuel : C — arbre — m — p — l — o — tente. L'arbre occupe la
       place du "a" donc il s'anime comme une lettre dans la séquence. */
    .stage-stagger.play .svg-wrap :global(.cm-l0)     { animation-delay: 100ms; }
    .stage-stagger.play .svg-wrap :global(.cm-tree-s) { animation-delay: 220ms; }
    .stage-stagger.play .svg-wrap :global(.cm-l1)     { animation-delay: 340ms; }
    .stage-stagger.play .svg-wrap :global(.cm-l2)     { animation-delay: 460ms; }
    .stage-stagger.play .svg-wrap :global(.cm-l3)     { animation-delay: 580ms; }
    .stage-stagger.play .svg-wrap :global(.cm-l4)     { animation-delay: 700ms; }
    .stage-stagger.play .svg-wrap :global(.cm-tent-move) {
      animation: stag-tent 820ms cubic-bezier(0.25, 0.8, 0.35, 1) 880ms forwards;
    }
    @keyframes stag-in {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes stag-tent {
      0%   { opacity: 0; transform: translateY(22px); animation-timing-function: cubic-bezier(0.3, 0, 0.2, 1); }
      45%  { opacity: 1; }
      55%  { transform: translateY(-4px); animation-timing-function: cubic-bezier(0.33, 0, 0.4, 1); }
      100% { opacity: 1; transform: translateY(0); }
    }

    /* ───── DEMO 3 : AMBIENT ───── */
    .stage-ambient .svg-wrap :global(.cm-tree-a) {
      transform-origin: 50% 100%;
      animation: sway 6s ease-in-out infinite;
    }
    .stage-ambient .svg-wrap :global(.cm-tent-a) {
      transform-origin: 50% 100%;
      animation: breathe 3.2s ease-in-out infinite;
    }
    @keyframes sway {
      0%, 100% { transform: rotate(-0.6deg); }
      50%      { transform: rotate(0.6deg); }
    }
    @keyframes breathe {
      0%, 100% { transform: scale(1); }
      50%      { transform: scale(1.04); }
    }

    /* ───── DEMO 4 : WIPE L→R ───── */
    .stage-wipe .svg-wrap {
      clip-path: inset(0 100% 0 0);
    }
    .stage-wipe.play .svg-wrap {
      animation: wipe-reveal 900ms cubic-bezier(0.65, 0, 0.35, 1) 150ms forwards;
    }
    @keyframes wipe-reveal {
      from { clip-path: inset(0 100% 0 0); }
      to   { clip-path: inset(0 0 0 0); }
    }

    /* ───── DEMO 5 : TREE GROWS ───── */
    .stage-grow .svg-wrap :global(.cm-word-g),
    .stage-grow .svg-wrap :global(.cm-tent-move) {
      opacity: 0;
    }
    .stage-grow .svg-wrap :global(.cm-tent-move) {
      transform-box: fill-box;
      transform-origin: 50% 100%;
    }
    .stage-grow .svg-wrap :global(.cm-tree-g) {
      transform-origin: 50% 100%;
      transform: scaleY(0);
    }
    .stage-grow.play .svg-wrap :global(.cm-tree-g) {
      animation: grow-tree 720ms cubic-bezier(0.2, 0.9, 0.3, 1.15) 80ms forwards;
    }
    .stage-grow.play .svg-wrap :global(.cm-word-g) {
      animation: grow-word 560ms cubic-bezier(0.2, 0.7, 0.1, 1) 520ms forwards;
    }
    .stage-grow.play .svg-wrap :global(.cm-tent-move) {
      animation: grow-tent 520ms cubic-bezier(0.2, 1.4, 0.4, 1) 900ms forwards;
    }
    @keyframes grow-tree {
      from { transform: scaleY(0); }
      to   { transform: scaleY(1); }
    }
    @keyframes grow-word {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes grow-tent {
      0%   { opacity: 0; transform: translateY(18px) scaleY(0.3); }
      60%  { opacity: 1; }
      100% { opacity: 1; transform: translateY(0) scaleY(1); }
    }

    /* ───── DEMO 6 : LETTER 3D FLIP ───── */
    .stage-flip .svg-wrap :global(.cm-flip),
    .stage-flip .svg-wrap :global(.cm-tree-f),
    .stage-flip .svg-wrap :global(.cm-tent-move) {
      opacity: 0;
    }
    .stage-flip .svg-wrap :global(.cm-tent-move) {
      transform-box: fill-box;
      transform-origin: 50% 100%;
    }
    .stage-flip .svg-wrap :global(.cm-flip) {
      transform-box: fill-box;
      transform-origin: 50% 50%;
    }
    .stage-flip.play .svg-wrap :global(.cm-flip) {
      animation: flip-in 560ms cubic-bezier(0.3, 0.8, 0.3, 1.1) forwards;
    }
    .stage-flip.play .svg-wrap :global(.cm-f0) { animation-delay: 100ms; }
    .stage-flip.play .svg-wrap :global(.cm-f1) { animation-delay: 200ms; }
    .stage-flip.play .svg-wrap :global(.cm-f2) { animation-delay: 300ms; }
    .stage-flip.play .svg-wrap :global(.cm-f3) { animation-delay: 400ms; }
    .stage-flip.play .svg-wrap :global(.cm-f4) { animation-delay: 500ms; }
    .stage-flip.play .svg-wrap :global(.cm-tree-f) {
      animation: flip-fade 500ms cubic-bezier(0.2, 0.7, 0.1, 1) 650ms forwards;
    }
    .stage-flip.play .svg-wrap :global(.cm-tent-move) {
      animation: flip-tent 500ms cubic-bezier(0.2, 1.3, 0.4, 1) 850ms forwards;
    }
    @keyframes flip-in {
      from { opacity: 0; transform: perspective(600px) rotateY(85deg); }
      to   { opacity: 1; transform: perspective(600px) rotateY(0deg); }
    }
    @keyframes flip-fade {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes flip-tent {
      0%   { opacity: 0; transform: translateY(18px) scaleY(0.3); }
      60%  { opacity: 1; }
      100% { opacity: 1; transform: translateY(0) scaleY(1); }
    }
  </style>
</Layout>
