---
import Layout from '../layouts/Layout.astro';

// Exploration : 8 façons de densifier le hero sans l'alourdir.
// Chaque concept prend 100vh pour être évalué à sa vraie taille.
---

<Layout>
  <nav class="explorer-nav" aria-label="Navigation entre concepts">
    <a href="#c1">01</a>
    <a href="#c2">02</a>
    <a href="#c3">03</a>
    <a href="#c4">04</a>
    <a href="#c5">05</a>
    <a href="#c6">06</a>
    <a href="#c7">07</a>
    <a href="#c8">08</a>
    <a href="#c9">09</a>
  </nav>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 01 — STATUS EYEBROW (live indicator en haut)
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c1" id="c1">
    <span class="concept-tag">01 · Status eyebrow</span>
    <div class="hero-inner">
      <p class="top-status">
        <span class="status-dot" aria-hidden="true"></span>
        En ligne au Camping de la Joie
      </p>
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 02 — PILLS PRODUITS sous la tagline
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c2" id="c2">
    <span class="concept-tag">02 · Pills produits</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
      <div class="pill-row">
        <span class="pill">Site public</span>
        <span class="pill">CRM desktop</span>
        <span class="pill">Québec</span>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 03 — CTA BUTTON sous la tagline
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c3" id="c3">
    <span class="concept-tag">03 · CTA button</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
      <a class="cta" href="#produits">
        <span>Voir les produits</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
      <p class="cta-fallback">ou <a href="#contact">écrivez-nous un mot</a></p>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 04 — DÉCORATEURS DE COINS (magazine cover)
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c4" id="c4">
    <span class="concept-tag">04 · Magazine corners</span>
    <span class="corner corner-tl">Édition 01 / Saison 2026</span>
    <span class="corner corner-tr">Agence · QC</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
    </div>
    <span class="corner corner-bl">↓ Faites défiler</span>
    <span class="corner corner-br">Fait pour les campings indépendants</span>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 05 — SOCIAL PROOF CHIP
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c5" id="c5">
    <span class="concept-tag">05 · Social proof chip</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
      <a class="proof-chip" href="#present-dans">
        <img src="/partners/delajoie-logo.png" alt="" aria-hidden="true" />
        <span>Présent au <strong>Camping de la Joie</strong> · Site + CRM</span>
        <span class="proof-arrow" aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 06 — TICKER / RUNNING LINE
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c6" id="c6">
    <span class="concept-tag">06 · Ticker line</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
    </div>
    <div class="ticker">
      <div class="ticker-track">
        <span>Saison 2026</span><span class="sep">·</span>
        <span>Conçu au Québec</span><span class="sep">·</span>
        <span>Zéro commission</span><span class="sep">·</span>
        <span>Support 48h</span><span class="sep">·</span>
        <span>Saison 2026</span><span class="sep">·</span>
        <span>Conçu au Québec</span><span class="sep">·</span>
        <span>Zéro commission</span><span class="sep">·</span>
        <span>Support 48h</span><span class="sep">·</span>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 07 — SCROLL HINT en bas
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c7" id="c7">
    <span class="concept-tag">07 · Scroll hint</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
    </div>
    <a class="scroll-hint" href="#produits" aria-label="Défiler vers le bas">
      <span>Défiler</span>
      <span class="scroll-line" aria-hidden="true"></span>
    </a>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 08 — STATS
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c8" id="c8">
    <span class="concept-tag">08 · Stats</span>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
      <div class="stats">
        <div class="stat">
          <span class="stat-num">1</span>
          <span class="stat-label">Camping équipé</span>
        </div>
        <span class="stat-sep" aria-hidden="true"></span>
        <div class="stat">
          <span class="stat-num">162</span>
          <span class="stat-label">Emplacements</span>
        </div>
        <span class="stat-sep" aria-hidden="true"></span>
        <div class="stat">
          <span class="stat-num">0</span>
          <span class="stat-label">Commission</span>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════════════════════════
      CONCEPT 09 — COMBO RECOMMANDÉ (status + chip + scroll)
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="hero c9" id="c9">
    <span class="concept-tag">09 · Combo recommandé</span>
    <p class="top-status">
      <span class="status-dot" aria-hidden="true"></span>
      En ligne au Camping de la Joie · Saison 2026
    </p>
    <div class="hero-inner">
      <h1 class="wordmark"><img src="/brand/camplo-wordmark.svg" alt="Camplo" /></h1>
      <p class="tagline">
        Un site qui <em>encaisse</em>. Un logiciel qui <em>opère</em>.
      </p>
      <a class="proof-chip" href="#present-dans">
        <img src="/partners/delajoie-logo.png" alt="" aria-hidden="true" />
        <span>Voir le <strong>Camping de la Joie</strong></span>
        <span class="proof-arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <a class="scroll-hint" href="#produits" aria-label="Défiler vers le bas">
      <span>Défiler</span>
      <span class="scroll-line" aria-hidden="true"></span>
    </a>
  </section>
</Layout>

<style>
  /* Navigation flottante entre concepts */
  .explorer-nav {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--ink);
    color: var(--paper);
    padding: 6px;
    border-radius: 9999px;
  }
  .explorer-nav a {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    color: var(--paper);
    text-decoration: none;
    border-radius: 9999px;
    opacity: 0.6;
    transition: opacity 200ms ease, background-color 200ms ease;
  }
  .explorer-nav a:hover {
    opacity: 1;
    background: rgba(246, 240, 224, 0.1);
  }

  /* Hero commun à tous les concepts */
  .hero {
    position: relative;
    background: var(--paper);
    height: 100vh;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    padding: clamp(48px, 8vw, 120px) var(--wrap-pad-x);
    text-align: center;
    box-sizing: border-box;
    border-bottom: 2px dashed var(--rule);
    overflow: hidden;
  }

  .concept-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    padding: 6px 12px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--marmalade);
    border-radius: 9999px;
    z-index: 10;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(28px, 4vw, 56px);
    max-width: 960px;
    width: 100%;
  }

  .wordmark {
    margin: 0;
    width: 100%;
    max-width: 720px;
    padding: 0 clamp(24px, 5vw, 64px);
    line-height: 0;
  }
  .wordmark img {
    width: 100%;
    height: auto;
    display: block;
  }

  .tagline {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 28px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--ink-soft);
  }
  .tagline em {
    font-style: italic;
    color: var(--marmalade);
  }

  /* ═══════════════════════════════════════════
     01 — STATUS EYEBROW
     ═══════════════════════════════════════════ */
  .top-status {
    position: absolute;
    top: 120px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--marmalade);
    position: relative;
  }
  .status-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1.5px solid var(--marmalade);
    opacity: 0.5;
    animation: pulse 2.4s cubic-bezier(0.22, 1, 0.36, 1) infinite;
  }
  @keyframes pulse {
    0% { transform: scale(0.6); opacity: 0.8; }
    80%, 100% { transform: scale(1.6); opacity: 0; }
  }

  /* ═══════════════════════════════════════════
     02 — PILLS
     ═══════════════════════════════════════════ */
  .pill-row {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .pill {
    padding: 8px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fern);
    border: 1px solid var(--fern);
    border-radius: 9999px;
    background: transparent;
  }

  /* ═══════════════════════════════════════════
     03 — CTA
     ═══════════════════════════════════════════ */
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: background-color 200ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta:hover {
    background: var(--marmalade);
    transform: translateY(-2px);
  }
  .cta-arrow {
    font-family: var(--font-display);
    font-style: italic;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cta:hover .cta-arrow {
    transform: translateX(4px);
  }
  .cta-fallback {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--ink-muted);
  }
  .cta-fallback a {
    color: var(--fern);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1px;
  }

  /* ═══════════════════════════════════════════
     04 — MAGAZINE CORNERS
     ═══════════════════════════════════════════ */
  .corner {
    position: absolute;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .corner-tl { top: 36px; left: 36px; }
  .corner-tr { top: 36px; right: 36px; }
  .corner-bl { bottom: 36px; left: 36px; }
  .corner-br { bottom: 36px; right: 36px; max-width: 200px; text-align: right; }

  /* ═══════════════════════════════════════════
     05 / 09 — SOCIAL PROOF CHIP
     ═══════════════════════════════════════════ */
  .proof-chip {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 18px 8px 8px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 9999px;
    text-decoration: none;
    font-family: var(--font-label);
    font-size: 12px;
    letter-spacing: 0.04em;
    transition: background-color 200ms ease, transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proof-chip:hover { transform: translateY(-2px); }
  .proof-chip img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    padding: 4px;
    background: var(--paper);
    border-radius: 50%;
  }
  .proof-chip strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
  }
  .proof-arrow {
    color: var(--marmalade);
    font-family: var(--font-display);
    font-style: italic;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .proof-chip:hover .proof-arrow {
    transform: translateY(2px);
  }

  /* ═══════════════════════════════════════════
     06 — TICKER
     ═══════════════════════════════════════════ */
  .ticker {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    overflow: hidden;
    background: var(--ink);
    color: var(--paper);
    padding: 14px 0;
  }
  .ticker-track {
    display: inline-flex;
    gap: 18px;
    white-space: nowrap;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    animation: ticker-scroll 28s linear infinite;
  }
  .ticker .sep { color: var(--marmalade); }
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ═══════════════════════════════════════════
     07 / 09 — SCROLL HINT
     ═══════════════════════════════════════════ */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, var(--marmalade) 50%, transparent 50%);
    background-size: 100% 12px;
    animation: scroll-line 1.8s ease-in-out infinite;
  }
  @keyframes scroll-line {
    from { background-position: 0 -36px; }
    to   { background-position: 0 36px; }
  }

  /* ═══════════════════════════════════════════
     08 — STATS
     ═══════════════════════════════════════════ */
  .stats {
    display: inline-flex;
    align-items: center;
    gap: clamp(20px, 3vw, 40px);
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4vw, 52px);
    letter-spacing: -0.02em;
    color: var(--fern);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .stat-sep {
    width: 1px;
    height: 28px;
    background: var(--rule);
  }
</style>
