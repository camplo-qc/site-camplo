---
import Layout from '../layouts/Layout.astro';

// Exploration : 5 directions pour la section 04 "Présent dans" qui montre
// Camping de la Joie. Chaque concept est autonome et doit pouvoir tenir
// comme section complète.
---

<Layout>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Exploration · Section 04</p>
      <h1>5 directions pour « Présent dans ».</h1>
      <p class="lede">
        Un seul partenaire à montrer, mais il faut que ça ait de la
        présence éditoriale. Voici 5 angles : baseline, ribbon, inline
        éditorial, pull-quote, backdrop géant.
      </p>
    </header>

    {/* ══════════════════════════════════════════════════════════════════
        V1 — BASELINE (current : logo centré + caption)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="v v1">
      <div class="v-label">V1 · Baseline (actuel)</div>

      <div class="v1-block">
        <div class="v1-head">
          <p class="eyebrow">
            <span class="eyebrow-num">04</span> · Présent dans
          </p>
          <h2 class="v1-title">Ils nous ont <em>fait confiance</em>.</h2>
          <p class="v1-note">Un premier camping déjà équipé.</p>
        </div>
        <a class="v1-logo-wrap" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" class="v1-logo" />
          <span class="v1-cap">Site + CRM · 2026</span>
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V2 — RIBBON HORIZONTAL (press-style "as seen on")
        ══════════════════════════════════════════════════════════════════ */}
    <section class="v v2">
      <div class="v-label">V2 · Ribbon horizontal</div>

      <div class="v2-ribbon">
        <span class="v2-kicker">Présent dans</span>
        <span class="v2-rule" aria-hidden="true"></span>
        <a class="v2-client" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.png" alt="Camping de la Joie" />
          <span class="v2-name">Camping de la Joie</span>
        </a>
        <span class="v2-rule" aria-hidden="true"></span>
        <span class="v2-tag">Site + CRM · 2026</span>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V3 — ÉDITORIAL INLINE (logo dans un paragraphe)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="v v3">
      <div class="v-label">V3 · Éditorial inline</div>

      <div class="v3-block">
        <p class="eyebrow"><span class="eyebrow-num">04</span> · Présent dans</p>
        <p class="v3-paragraph">
          Depuis 2026, Camplo opère
          <a href="https://delajoiequebec.com" target="_blank" rel="noopener" class="v3-client">
            <img src="/partners/delajoie-logo.png" alt="" aria-hidden="true" />
            <span>Camping de la Joie</span>
          </a>
          — 162 emplacements dans les <em>Laurentides</em>, avec un site
          public et un logiciel de gestion complet. D'autres campings s'ajouteront
          pour la saison 2027.
        </p>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V4 — PULL QUOTE (citation éditoriale avec logo discret)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="v v4">
      <div class="v-label">V4 · Pull quote</div>

      <div class="v4-block">
        <span class="v4-marker" aria-hidden="true">※</span>
        <p class="v4-quote">
          Le <em>Camping de la Joie</em> (Laurentides) tourne sur Camplo
          depuis la saison 2026. Site public, logiciel de gestion, tout.
        </p>
        <a class="v4-credit" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.png" alt="" aria-hidden="true" />
          <span>
            delajoiequebec.com
            <span class="v4-arrow" aria-hidden="true">↗</span>
          </span>
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        V5 — BACKDROP GÉANT (logo en filigrane XXL + détails overlayés)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="v v5">
      <div class="v-label">V5 · Backdrop géant</div>

      <div class="v5-block">
        <img src="/partners/delajoie-logo.png" alt="" aria-hidden="true" class="v5-bg" />
        <div class="v5-content">
          <p class="eyebrow"><span class="eyebrow-num">04</span> · Présent dans</p>
          <h2 class="v5-title"><em>Camping de la Joie</em>.</h2>
          <dl class="v5-facts">
            <div>
              <dt>Région</dt>
              <dd>Laurentides</dd>
            </div>
            <div>
              <dt>Taille</dt>
              <dd>162 emplacements</dd>
            </div>
            <div>
              <dt>Équipé de</dt>
              <dd>Site + CRM</dd>
            </div>
            <div>
              <dt>Depuis</dt>
              <dd>2026</dd>
            </div>
          </dl>
          <a class="v5-link" href="https://delajoiequebec.com" target="_blank" rel="noopener">
            delajoiequebec.com <span class="v5-arrow" aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ───── Page shell ───── */
  .page {
    padding: clamp(48px, 7vw, 96px) 0 clamp(64px, 8vw, 120px);
  }
  .page-head {
    max-width: 880px;
    margin: 0 auto clamp(56px, 7vw, 96px);
    padding: 0 var(--wrap-pad-x);
  }
  .page-head .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
  }
  .page-head h1 {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  .page-head .lede {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(16px, 1.3vw, 19px);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 54ch;
  }

  /* ───── Section wrappers & label ───── */
  .v {
    margin-bottom: clamp(40px, 5vw, 72px);
    padding: 0 var(--wrap-pad-x);
  }
  .v-label {
    display: inline-block;
    padding: 6px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9999px;
    margin-bottom: 20px;
  }

  /* Eyebrow commun */
  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
    margin: 0;
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  /* ═══════════════════════════════════════════
     V1 — BASELINE
     ═══════════════════════════════════════════ */
  .v1-block {
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: clamp(48px, 6vw, 80px) clamp(24px, 3vw, 48px);
    border-radius: 4px;
  }
  .v1-head {
    max-width: 640px;
  }
  .v1-title {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 5vw, 56px);
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
  }
  .v1-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }
  .v1-note {
    margin-top: 14px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 17px;
    color: var(--ink-soft);
  }
  .v1-logo-wrap {
    margin-top: 48px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .v1-logo-wrap:hover { transform: translateY(-2px); }
  .v1-logo {
    height: clamp(80px, 9vw, 112px);
    width: auto;
  }
  .v1-cap {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  /* ═══════════════════════════════════════════
     V2 — RIBBON HORIZONTAL
     ═══════════════════════════════════════════ */
  .v2-ribbon {
    display: flex;
    align-items: center;
    gap: clamp(16px, 2vw, 28px);
    padding: clamp(20px, 2.5vw, 32px) clamp(24px, 3vw, 40px);
    background: var(--paper-warm);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .v2-kicker {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
    flex-shrink: 0;
  }
  .v2-rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
    min-width: 30px;
  }
  .v2-client {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--ink);
    transition: opacity 240ms ease;
  }
  .v2-client:hover { opacity: 0.75; }
  .v2-client img {
    height: 48px;
    width: auto;
  }
  .v2-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.015em;
  }
  .v2-tag {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════
     V3 — ÉDITORIAL INLINE
     ═══════════════════════════════════════════ */
  .v3-block {
    max-width: 720px;
    padding: clamp(32px, 4vw, 56px) 0;
  }
  .v3-paragraph {
    margin: 22px 0 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 28px);
    letter-spacing: -0.01em;
    line-height: 1.45;
    color: var(--ink);
  }
  .v3-paragraph em {
    font-style: italic;
    color: var(--fern);
  }
  .v3-client {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--fern);
    border-bottom: 2px solid var(--marmalade);
    padding: 0 4px 2px;
    transition: color 240ms ease;
    font-style: italic;
    font-weight: 500;
  }
  .v3-client:hover { color: var(--marmalade); }
  .v3-client img {
    height: 28px;
    width: auto;
    vertical-align: middle;
  }

  /* ═══════════════════════════════════════════
     V4 — PULL QUOTE
     ═══════════════════════════════════════════ */
  .v4-block {
    max-width: 720px;
    padding: clamp(40px, 5vw, 64px) clamp(24px, 3vw, 40px);
    border-left: 3px solid var(--marmalade);
    position: relative;
  }
  .v4-marker {
    position: absolute;
    top: clamp(40px, 5vw, 64px);
    left: clamp(24px, 3vw, 40px);
    transform: translateY(-2px);
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--marmalade);
    line-height: 0.6;
  }
  .v4-quote {
    margin: 0 0 0 56px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(22px, 2.4vw, 32px);
    letter-spacing: -0.01em;
    line-height: 1.4;
    color: var(--ink);
  }
  .v4-quote em {
    color: var(--fern);
    font-style: italic;
  }
  .v4-credit {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin: 28px 0 0 56px;
    text-decoration: none;
    color: var(--ink-muted);
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: color 240ms ease;
  }
  .v4-credit:hover { color: var(--marmalade); }
  .v4-credit img {
    height: 36px;
    width: auto;
  }
  .v4-arrow {
    font-style: italic;
    font-size: 14px;
    color: var(--marmalade);
    margin-left: 4px;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .v4-credit:hover .v4-arrow {
    transform: translate(3px, -3px);
  }

  /* ═══════════════════════════════════════════
     V5 — BACKDROP GÉANT
     ═══════════════════════════════════════════ */
  .v5-block {
    position: relative;
    background: var(--paper-warm);
    padding: clamp(40px, 5vw, 80px) clamp(24px, 3vw, 48px);
    overflow: hidden;
    border-radius: 4px;
    min-height: 360px;
  }
  .v5-bg {
    position: absolute;
    right: -4%;
    top: 50%;
    transform: translateY(-50%);
    height: clamp(280px, 42vw, 560px);
    width: auto;
    opacity: 0.12;
    pointer-events: none;
    user-select: none;
  }
  .v5-content {
    position: relative;
    z-index: 1;
    max-width: 640px;
  }
  .v5-title {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(40px, 6vw, 80px);
    letter-spacing: -0.03em;
    line-height: 0.95;
    color: var(--ink);
  }
  .v5-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }
  .v5-facts {
    margin: clamp(32px, 4vw, 48px) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, auto));
    gap: 20px 48px;
  }
  .v5-facts > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .v5-facts dt {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .v5-facts dd {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 18px;
    color: var(--ink);
  }
  .v5-link {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    margin-top: clamp(32px, 4vw, 48px);
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fern);
    text-decoration: none;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 4px;
    transition: color 240ms ease;
  }
  .v5-link:hover { color: var(--marmalade); }
  .v5-arrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 14px;
    color: var(--marmalade);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .v5-link:hover .v5-arrow {
    transform: translate(3px, -3px);
  }

  @media (max-width: 640px) {
    .v5-facts {
      grid-template-columns: 1fr;
    }
  }
</style>
