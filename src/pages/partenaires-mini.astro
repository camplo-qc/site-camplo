---
import Layout from '../layouts/Layout.astro';

// Exploration : 5 concepts pour présenter Camping de la Joie de façon plus
// discrète que la grosse card actuelle. Scroll pour comparer.
---

<Layout>
  <main class="page">
    <header class="page-head">
      <p class="eyebrow">Exploration · Partenaires</p>
      <h1>5 façons de présenter Camping de la Joie, en plus petit.</h1>
      <p class="lede">
        La grosse card actuelle prend trop d'espace pour un seul
        partenaire. Voici 5 directions plus sobres : ligne, logo wall,
        pill, callout, annotation éditoriale.
      </p>
    </header>

    {/* ══════════════════════════════════════════════════════════════════
        CONCEPT 01 — LIGNE (single horizontal row)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="c1">
      <div class="label">Concept 01 · Ligne</div>
      <p class="note">Compact, journalistique. Prend une seule ligne sur desktop.</p>

      <div class="c1-wrap">
        <a class="c1-row" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img class="c1-logo" src="/partners/delajoie-logo.jpg" alt="Camping de la Joie" />
          <span class="c1-name"><strong>Camping de la Joie</strong></span>
          <span class="c1-sep" aria-hidden="true">/</span>
          <span class="c1-meta">Laurentides · 162 emplacements · Depuis 2026</span>
          <span class="c1-services">
            <span class="c1-pill">Site</span>
            <span class="c1-pill">CRM</span>
          </span>
          <span class="c1-arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        CONCEPT 02 — LOGO WALL (press-style, with tiny caption)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="c2">
      <div class="label">Concept 02 · Logo wall</div>
      <p class="note">Style "ils nous font confiance" avec logo seulement. Laisse de la place pour d'autres clients à venir.</p>

      <div class="c2-wrap">
        <p class="c2-heading">Présent dans</p>
        <div class="c2-grid">
          <a class="c2-item" href="https://delajoiequebec.com" target="_blank" rel="noopener">
            <img src="/partners/delajoie-logo.jpg" alt="Camping de la Joie" />
            <span class="c2-cap">Site + CRM</span>
          </a>
          <div class="c2-item c2-item--empty" aria-hidden="true">
            <div class="c2-placeholder"></div>
            <span class="c2-cap">Saison 2027</span>
          </div>
          <div class="c2-item c2-item--empty" aria-hidden="true">
            <div class="c2-placeholder"></div>
            <span class="c2-cap">Saison 2027</span>
          </div>
        </div>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        CONCEPT 03 — PILL (inline capsule)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="c3">
      <div class="label">Concept 03 · Pill</div>
      <p class="note">Capsule rounded-full, style "stamp certifié" — très compacte.</p>

      <div class="c3-wrap">
        <a class="c3-pill" href="https://delajoiequebec.com" target="_blank" rel="noopener">
          <img src="/partners/delajoie-logo.jpg" alt="" aria-hidden="true" />
          <span class="c3-txt">
            <strong>Camping de la Joie</strong>
            <span class="c3-meta">Laurentides · Site + CRM</span>
          </span>
          <span class="c3-arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        CONCEPT 04 — CALLOUT ÉDITORIAL (pull quote style)
        ══════════════════════════════════════════════════════════════════ */}
    <section class="c4">
      <div class="label">Concept 04 · Callout éditorial</div>
      <p class="note">Comme une citation en marge. Italique, minuscule logo en corner.</p>

      <div class="c4-wrap">
        <figure class="c4">
          <blockquote class="c4-quote">
            <span class="c4-bullet" aria-hidden="true">※</span>
            Site public <em>et</em> CRM livrés au
            <a href="https://delajoiequebec.com" target="_blank" rel="noopener">
              <img src="/partners/delajoie-logo.jpg" alt="" aria-hidden="true" />
              Camping de la Joie
            </a>
            en 2026 — Laurentides, 162 emplacements.
          </blockquote>
        </figure>
      </div>
    </section>

    {/* ══════════════════════════════════════════════════════════════════
        CONCEPT 05 — ANNOTATION / NOTE DE MARGE
        ══════════════════════════════════════════════════════════════════ */}
    <section class="c5">
      <div class="label">Concept 05 · Note de marge</div>
      <p class="note">Style annotation éditoriale, avec label uppercase + détails inline.</p>

      <div class="c5-wrap">
        <div class="c5-note">
          <p class="c5-kicker"><span class="c5-num">01</span> · Partenaire</p>
          <div class="c5-body">
            <img class="c5-logo" src="/partners/delajoie-logo.jpg" alt="" aria-hidden="true" />
            <div class="c5-text">
              <a href="https://delajoiequebec.com" class="c5-name" target="_blank" rel="noopener">
                Camping de la Joie <span class="c5-arrow" aria-hidden="true">↗</span>
              </a>
              <p class="c5-meta">Laurentides · 162 emplacements · Site + CRM depuis 2026</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page {
    padding: clamp(48px, 7vw, 96px) var(--wrap-pad-x) clamp(72px, 9vw, 128px);
    max-width: 960px;
    margin: 0 auto;
  }

  .page-head {
    margin-bottom: clamp(56px, 7vw, 96px);
  }
  .page-head .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
  }
  .page-head h1 {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(28px, 4vw, 48px);
    letter-spacing: -0.025em;
    line-height: 1.1;
  }
  .page-head .lede {
    margin-top: 16px;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(15px, 1.2vw, 18px);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 52ch;
  }

  /* Sections commun */
  .c1, .c2, .c3, .c4, .c5 {
    margin-bottom: clamp(56px, 6vw, 80px);
  }
  .label {
    display: inline-block;
    padding: 6px 14px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    border-radius: 9999px;
    margin-bottom: 10px;
  }
  .note {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    color: var(--ink-soft);
    margin: 0 0 28px;
    line-height: 1.5;
  }

  /* ═══════════════════════════════════════════
     CONCEPT 01 — LIGNE
     ═══════════════════════════════════════════ */
  .c1-wrap {
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .c1-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 4px;
    text-decoration: none;
    color: var(--ink);
    transition: background-color 240ms ease;
  }
  .c1-row:hover {
    background: var(--paper-warm);
  }
  .c1-logo {
    width: 36px;
    height: 36px;
    object-fit: contain;
    mix-blend-mode: multiply;
    flex-shrink: 0;
  }
  .c1-name {
    font-family: var(--font-display);
    font-size: 17px;
    line-height: 1.1;
  }
  .c1-name strong {
    font-weight: 700;
  }
  .c1-sep {
    color: var(--ink-muted);
    font-family: var(--font-display);
    font-style: italic;
  }
  .c1-meta {
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
    flex: 1;
    min-width: 0;
  }
  .c1-services {
    display: inline-flex;
    gap: 6px;
    flex-shrink: 0;
  }
  .c1-pill {
    padding: 5px 11px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fern);
    border: 1px solid var(--fern);
    border-radius: 9999px;
    line-height: 1;
  }
  .c1-arrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--marmalade);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    flex-shrink: 0;
  }
  .c1-row:hover .c1-arrow {
    transform: translate(3px, -3px);
  }
  @media (max-width: 720px) {
    .c1-row {
      flex-wrap: wrap;
      gap: 10px 14px;
    }
    .c1-sep { display: none; }
    .c1-meta {
      flex: 0 0 100%;
      padding-left: 52px;
      margin-top: -6px;
    }
  }

  /* ═══════════════════════════════════════════
     CONCEPT 02 — LOGO WALL
     ═══════════════════════════════════════════ */
  .c2-wrap {
    padding: 36px 24px;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--paper);
  }
  .c2-heading {
    text-align: center;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
    margin: 0 0 28px;
  }
  .c2-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    align-items: center;
  }
  .c2-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-left: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: opacity 240ms ease;
  }
  .c2-item:first-child { border-left: none; }
  .c2-item img {
    height: 56px;
    width: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
    transition: opacity 240ms ease;
  }
  .c2-item:hover img { opacity: 0.7; }
  .c2-placeholder {
    width: 70px;
    height: 56px;
    border: 1px dashed var(--ink-muted);
    border-radius: 4px;
    opacity: 0.4;
  }
  .c2-cap {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .c2-item--empty { cursor: default; }

  /* ═══════════════════════════════════════════
     CONCEPT 03 — PILL
     ═══════════════════════════════════════════ */
  .c3-wrap {
    display: flex;
    justify-content: center;
  }
  .c3-pill {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 10px 22px 10px 10px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 9999px;
    text-decoration: none;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .c3-pill:hover {
    transform: translateY(-2px);
  }
  .c3-pill img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: contain;
    background: var(--paper);
    padding: 4px;
    flex-shrink: 0;
  }
  .c3-txt {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .c3-txt strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
  }
  .c3-meta {
    font-family: var(--font-label);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(246, 240, 224, 0.7);
  }
  .c3-arrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 15px;
    color: var(--marmalade);
    margin-left: 8px;
  }

  /* ═══════════════════════════════════════════
     CONCEPT 04 — CALLOUT ÉDITORIAL
     ═══════════════════════════════════════════ */
  .c4-wrap {
    padding: 32px 0;
  }
  .c4-quote {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(20px, 2.2vw, 28px);
    letter-spacing: -0.01em;
    line-height: 1.4;
    color: var(--ink);
    max-width: 44ch;
    position: relative;
    padding-left: 36px;
  }
  .c4-quote em {
    font-style: italic;
    color: var(--marmalade);
  }
  .c4-bullet {
    position: absolute;
    left: 0;
    top: 0.1em;
    font-size: 24px;
    color: var(--marmalade);
    font-family: var(--font-display);
  }
  .c4-quote a {
    color: var(--fern);
    text-decoration: none;
    border-bottom: 1.5px solid var(--marmalade);
    padding-bottom: 1px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-style: italic;
    transition: color 240ms ease;
  }
  .c4-quote a:hover {
    color: var(--marmalade);
  }
  .c4-quote a img {
    width: 22px;
    height: 22px;
    object-fit: contain;
    mix-blend-mode: multiply;
    display: inline-block;
    vertical-align: middle;
  }

  /* ═══════════════════════════════════════════
     CONCEPT 05 — ANNOTATION
     ═══════════════════════════════════════════ */
  .c5-wrap {
    display: flex;
  }
  .c5-note {
    padding: 20px 24px;
    border-left: 3px solid var(--marmalade);
    background: var(--paper-warm);
    max-width: 480px;
  }
  .c5-kicker {
    margin: 0 0 12px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .c5-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 13px;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    margin-right: 2px;
  }
  .c5-body {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .c5-logo {
    width: 46px;
    height: 46px;
    object-fit: contain;
    mix-blend-mode: multiply;
    flex-shrink: 0;
  }
  .c5-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .c5-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    transition: color 240ms ease;
  }
  .c5-name:hover { color: var(--marmalade); }
  .c5-arrow {
    font-style: italic;
    color: var(--marmalade);
    font-size: 16px;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    display: inline-block;
  }
  .c5-name:hover .c5-arrow {
    transform: translate(3px, -3px);
  }
  .c5-meta {
    margin: 0;
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
</style>
