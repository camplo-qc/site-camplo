---
import Layout from '../layouts/Layout.astro';

// Paths extraits de camplo-mark.svg, coords normalisées (pas de translate externe requis).
// Tree : top à y=3, bottom path y=42, visible avec stroke y=1.25..43.75
const TREE_PATH =
  '<path d="M 29.25 3 L 30.75 3 L 47.43 19.44 L 47.2 20 L 40 20 L 57.49 41.38 L 57.2 42 L 2.8 42 L 2.51 41.38 L 20 20 L 12.8 20 L 12.57 19.44 Z" fill="#3E6B31" stroke="#3E6B31" stroke-width="3.5" stroke-linejoin="miter" stroke-miterlimit="4"/>';
// Tente et fente : coords shiftées +3 pour que leurs centres soient alignés
// (la fente originale est dans le mark space, la tente dans translate(3,0))
const TENT_PATH =
  '<path d="M 32.5 27 L 33.5 27 L 48.60 53.31 L 48.2 54 L 17.8 54 L 17.40 53.31 Z" fill="#E8853B"/>';
const TENT_DOOR =
  '<path d="M 32.5 40 L 33.5 40 L 36 54.5 L 30 54.5 Z" fill="#F6F0E0"/>';

// Helpers : place tree/tent avec BOTTOM sur `baseline` (y). `variation` pour terrain roulant.
// Tree bottom visible = y=43.75 (path 42 + stroke 1.75)
const tree = (x: number, baseline: number, scale: number, variation = 0) => {
  const y = baseline - 43.75 * scale + variation;
  return `<g transform="translate(${x}, ${y}) scale(${scale})">${TREE_PATH}</g>`;
};
// Tent bottom = y=54
const tent = (x: number, baseline: number, scale: number, variation = 0) => {
  const y = baseline - 54 * scale + variation;
  return `<g transform="translate(${x}, ${y}) scale(${scale})">${TENT_PATH}${TENT_DOOR}</g>`;
};

// === Option B — scatter avec profondeur, 4 plans baseline-aligned ===
// Baselines (de l'arrière vers l'avant) : l'arrière est plus haut (effet distance)
const BL = { back: 195, far: 210, mid: 222, front: 232 };

const sceneB = [
  // Plan 4 (fond dense, petit, pâle)
  `<g opacity="0.22">`,
  tree(20,   BL.back, 0.72, -1),
  tree(75,   BL.back, 0.68, 1),
  tree(130,  BL.back, 0.75, -2),
  tree(185,  BL.back, 0.70, 0),
  tree(240,  BL.back, 0.72, 1),
  tree(295,  BL.back, 0.80, -3),
  tree(355,  BL.back, 0.68, 0),
  tree(408,  BL.back, 0.73, -1),
  tree(465,  BL.back, 0.68, 2),
  tree(520,  BL.back, 0.76, -2),
  tree(580,  BL.back, 0.70, 1),
  tree(635,  BL.back, 0.74, -1),
  tree(695,  BL.back, 0.78, -2),
  tree(755,  BL.back, 0.66, 1),
  tree(810,  BL.back, 0.72, 0),
  tree(870,  BL.back, 0.76, -2),
  tree(930,  BL.back, 0.70, 1),
  tree(990,  BL.back, 0.74, 0),
  tree(1050, BL.back, 0.68, 2),
  tree(1105, BL.back, 0.77, -2),
  tree(1165, BL.back, 0.72, 0),
  `</g>`,

  // Plan 3 (loin, moyens-petits, terrain qui roule)
  `<g opacity="0.45">`,
  tree(35,   BL.far, 1.05, -2),
  tree(145,  BL.far, 0.95, 3),
  tree(265,  BL.far, 1.15, -4),
  tree(380,  BL.far, 1.00, 1),
  tree(490,  BL.far, 1.10, -3),
  tree(605,  BL.far, 0.90, 4),
  tree(715,  BL.far, 1.05, -2),
  tree(830,  BL.far, 0.98, 2),
  tree(940,  BL.far, 1.12, -4),
  tree(1060, BL.far, 1.00, 0),
  `</g>`,

  // Plan 2 (milieu, moyens + petite tente au loin)
  `<g opacity="0.78">`,
  tree(80,   BL.mid, 1.45, 0),
  tree(320,  BL.mid, 1.65, -3),
  tree(560,  BL.mid, 1.40, 2),
  tree(790,  BL.mid, 1.60, -2),
  tree(1010, BL.mid, 1.45, 0),
  tent(455,  BL.mid, 1.10, 0),
  `</g>`,

  // Plan 1 (avant, gros arbres + grosses tentes)
  tree(-20,  BL.front, 2.20, 0),
  tree(230,  BL.front, 2.55, -4),
  tree(640,  BL.front, 2.70, -2),
  tree(1040, BL.front, 2.45, 2),
  tent(155,  BL.front, 1.80, 0),
  tent(520,  BL.front, 1.65, 0),
  tent(870,  BL.front, 1.75, 0),
].join('');
---

<Layout title="Camplo · Bas du hero">
  <main>
    <header class="page-head">
      <p class="eyebrow">Démo · bas du hero</p>
      <h1>Remplir le vide sous le wordmark.</h1>
      <p class="lede">Quatre directions pour ajouter une petite scène forêt+tentes au pied du hero. Chaque variante montre le wordmark en contexte.</p>
    </header>

    <!-- OPTION A : Horizon forêt -->
    <section class="demo">
      <div class="demo-head">
        <p class="num">A</p>
        <h2>Horizon forêt — bande au sol</h2>
        <p class="desc">Rangée dense d'arbres de hauteurs variées qui fait un "terrain". Quelques tentes intercalées. Ancre visuel fort, sérieux.</p>
      </div>
      <div class="preview">
        <div class="hero-mock">
          <div class="hero-word">Camplo</div>
          <div class="tagline-mock">Un logiciel qui <em>ne date pas</em> de 2008.</div>
          <div class="scene scene-a">
            <svg viewBox="0 0 1200 180" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
              <!-- ground baseline -->
              <line x1="0" y1="178" x2="1200" y2="178" stroke="#3E6B31" stroke-width="1.5" opacity="0.35"/>
              <!-- trees -->
              <g transform="translate(20, 100) scale(1.6)" set:html={TREE_PATH} />
              <g transform="translate(110, 90) scale(1.8)" set:html={TREE_PATH} />
              <g transform="translate(210, 110) scale(1.4)" set:html={TREE_PATH} />
              <g transform="translate(295, 95) scale(1.7)" set:html={TREE_PATH} />
              <g transform="translate(390, 115) scale(1.3)" set:html={TREE_PATH} />
              <g transform="translate(465, 100) scale(1.55)" set:html={TREE_PATH} />
              <g transform="translate(555, 85) scale(1.9)" set:html={TREE_PATH} />
              <g transform="translate(660, 105) scale(1.45)" set:html={TREE_PATH} />
              <g transform="translate(745, 95) scale(1.7)" set:html={TREE_PATH} />
              <g transform="translate(840, 110) scale(1.4)" set:html={TREE_PATH} />
              <g transform="translate(920, 100) scale(1.6)" set:html={TREE_PATH} />
              <g transform="translate(1020, 85) scale(1.85)" set:html={TREE_PATH} />
              <g transform="translate(1115, 105) scale(1.45)" set:html={TREE_PATH} />
              <!-- tents -->
              <g transform="translate(165, 105) scale(1.35)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
              <g transform="translate(605, 100) scale(1.45)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
              <g transform="translate(965, 105) scale(1.4)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- OPTION B : Scatter avec profondeur (v2, amélioré) -->
    <section class="demo">
      <div class="demo-head">
        <p class="num">B</p>
        <h2>Scatter avec profondeur — v2</h2>
        <p class="desc">4 plans de profondeur au lieu de 3. Terrain qui roule (arbres à hauteurs variées au même plan), densité qui augmente avec la distance (forêt lointaine plus touffue), et une fine brume paper en bas pour les troncs du premier plan.</p>
      </div>
      <div class="preview">
        <div class="hero-mock">
          <div class="hero-word">Camplo</div>
          <div class="tagline-mock">Un logiciel qui <em>ne date pas</em> de 2008.</div>
          <div class="scene scene-b">
            <svg viewBox="0 0 1200 260" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
              <defs>
                <linearGradient id="fog" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#F6F0E0" stop-opacity="0"/>
                  <stop offset="100%" stop-color="#F6F0E0" stop-opacity="0.95"/>
                </linearGradient>
              </defs>
              <g set:html={sceneB} />
              <rect x="0" y="190" width="1200" height="70" fill="url(#fog)"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- OPTION C : Cluster minimal -->
    <section class="demo">
      <div class="demo-head">
        <p class="num">C</p>
        <h2>Cluster minimal asymétrique</h2>
        <p class="desc">3 arbres + 2 tentes groupés sur la gauche, reste en paper vide. Éditorial, beaucoup d'air, sensation exclusive.</p>
      </div>
      <div class="preview">
        <div class="hero-mock">
          <div class="hero-word">Camplo</div>
          <div class="tagline-mock">Un logiciel qui <em>ne date pas</em> de 2008.</div>
          <div class="scene scene-c">
            <svg viewBox="0 0 1200 180" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
              <g transform="translate(120, 40) scale(2.3)" set:html={TREE_PATH} />
              <g transform="translate(260, 55) scale(1.95)" set:html={TREE_PATH} />
              <g transform="translate(395, 70) scale(1.65)" set:html={TREE_PATH} />
              <g transform="translate(220, 90) scale(1.6)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
              <g transform="translate(330, 100) scale(1.35)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- OPTION D : Ligne horizon + tentes centrées -->
    <section class="demo">
      <div class="demo-head">
        <p class="num">D</p>
        <h2>Ligne horizon + tentes centrées</h2>
        <p class="desc">Une fine silhouette de forêt en arrière-plan (très pâle), avec 2-3 tentes au premier plan centrées sous le wordmark. Le wordmark reste vedette.</p>
      </div>
      <div class="preview">
        <div class="hero-mock">
          <div class="hero-word">Camplo</div>
          <div class="tagline-mock">Un logiciel qui <em>ne date pas</em> de 2008.</div>
          <div class="scene scene-d">
            <svg viewBox="0 0 1200 160" preserveAspectRatio="xMidYMax slice" aria-hidden="true">
              <!-- horizon forêt pâle -->
              <g opacity="0.22">
                <g transform="translate(0, 100) scale(1.0)" set:html={TREE_PATH} />
                <g transform="translate(80, 95) scale(1.1)" set:html={TREE_PATH} />
                <g transform="translate(170, 105) scale(0.95)" set:html={TREE_PATH} />
                <g transform="translate(250, 90) scale(1.2)" set:html={TREE_PATH} />
                <g transform="translate(345, 100) scale(1.0)" set:html={TREE_PATH} />
                <g transform="translate(430, 95) scale(1.1)" set:html={TREE_PATH} />
                <g transform="translate(520, 105) scale(0.95)" set:html={TREE_PATH} />
                <g transform="translate(600, 90) scale(1.15)" set:html={TREE_PATH} />
                <g transform="translate(695, 100) scale(1.05)" set:html={TREE_PATH} />
                <g transform="translate(785, 95) scale(1.1)" set:html={TREE_PATH} />
                <g transform="translate(880, 100) scale(1.0)" set:html={TREE_PATH} />
                <g transform="translate(965, 90) scale(1.2)" set:html={TREE_PATH} />
                <g transform="translate(1060, 100) scale(1.0)" set:html={TREE_PATH} />
                <g transform="translate(1145, 95) scale(1.05)" set:html={TREE_PATH} />
              </g>
              <!-- 3 tentes centrées -->
              <g transform="translate(475, 85) scale(1.55)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
              <g transform="translate(555, 70) scale(1.9)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
              <g transform="translate(660, 85) scale(1.55)">
                <Fragment set:html={TENT_PATH} />
                <Fragment set:html={TENT_DOOR} />
              </g>
            </svg>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    main {
      background: var(--paper);
      padding: clamp(40px, 6vw, 80px) 0 clamp(80px, 10vw, 140px);
    }

    .page-head {
      max-width: var(--wrap-max);
      margin: 0 auto;
      padding: 0 var(--wrap-pad-x);
    }
    .eyebrow {
      font-family: var(--font-label);
      font-weight: 600;
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--fern);
    }
    .page-head h1 {
      margin-top: 12px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(32px, 4vw, 52px);
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--ink);
    }
    .lede {
      margin-top: 14px;
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.6;
      color: var(--ink-soft);
      max-width: 56ch;
    }

    .demo {
      max-width: var(--wrap-max);
      margin: clamp(56px, 7vw, 96px) auto 0;
      padding: 0 var(--wrap-pad-x);
    }
    .demo-head {
      padding-bottom: 20px;
      border-bottom: 1px solid var(--rule);
    }
    .num {
      font-family: var(--font-display);
      font-style: italic;
      font-weight: 500;
      color: var(--marmalade);
      font-size: 16px;
    }
    .demo-head h2 {
      margin-top: 4px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(22px, 2.4vw, 30px);
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: var(--ink);
    }
    .desc {
      margin-top: 8px;
      font-family: var(--font-body);
      font-size: 15px;
      line-height: 1.55;
      color: var(--ink-soft);
      max-width: 62ch;
    }

    .preview {
      margin-top: clamp(24px, 3vw, 40px);
    }
    .hero-mock {
      background: var(--paper);
      border: 1px solid var(--rule);
      border-radius: 8px;
      padding: clamp(48px, 6vw, 96px) clamp(24px, 4vw, 64px) 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      overflow: hidden;
      position: relative;
    }
    .hero-word {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(56px, 9vw, 140px);
      letter-spacing: -0.035em;
      line-height: 1;
      color: var(--fern);
    }
    .tagline-mock {
      margin-top: clamp(20px, 3vw, 40px);
      font-family: var(--font-display);
      font-weight: 500;
      font-size: clamp(16px, 2vw, 26px);
      letter-spacing: -0.01em;
      line-height: 1.25;
      color: var(--ink-soft);
      max-width: 28ch;
      text-align: center;
    }
    .tagline-mock em {
      font-style: italic;
      color: var(--marmalade);
    }
    .scene {
      margin-top: clamp(32px, 5vw, 64px);
      width: 100%;
      max-width: 100%;
    }
    .scene svg {
      display: block;
      width: 100%;
      height: auto;
    }
  </style>
</Layout>
