---
import Layout from '../layouts/Layout.astro';

const sections = [
  { id: 'hero', label: 'Accueil', num: '00' },
  { id: 'produits', label: 'Produits', num: '01' },
  { id: 'faq', label: 'FAQ', num: '02' },
  { id: 'contact', label: 'Contact', num: '03' },
  { id: 'present', label: 'Présent dans', num: '04' },
];
---

<Layout>
  <aside class="scroll-indicator" aria-label="Navigation par section">
    <div class="si-track" aria-hidden="true">
      <div class="si-fill" data-fill></div>
    </div>

    <ul class="si-list">
      {sections.map((s, i) => (
        <li class="si-item" style={`--i: ${i}`}>
          <a href={`#${s.id}`} class="si-link" data-target={s.id}>
            <span class="si-marker" aria-hidden="true">
              <span class="si-dot"></span>
              <span class="si-tick"></span>
            </span>
            <span class="si-label">
              <span class="si-num">{s.num}</span>
              <span class="si-name">{s.label}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </aside>

  {/* Fake sections pour démontrer le tracking */}
  <section class="fake-section hero-demo" id="hero">
    <div>
      <p class="eyebrow">00 · Accueil</p>
      <h1 class="title">Hero</h1>
      <p class="sub">Scroll pour voir l'indicateur à gauche : progress fill marmalade qui monte, accent horizontal sur la section active, labels toujours visibles.</p>
    </div>
  </section>

  <section class="fake-section" id="produits">
    <div>
      <p class="eyebrow">01 · Produits</p>
      <h2 class="title">Produits</h2>
      <p class="sub">Le label devient ink sombre quand sa section est active, muted autrement. Le numéro reste italique marmalade.</p>
    </div>
  </section>

  <section class="fake-section" id="faq">
    <div>
      <p class="eyebrow">02 · FAQ</p>
      <h2 class="title">FAQ</h2>
      <p class="sub">Un petit trait horizontal apparaît à côté du dot actif, pointant vers le label comme une annotation éditoriale.</p>
    </div>
  </section>

  <section class="fake-section" id="contact">
    <div>
      <p class="eyebrow">03 · Contact</p>
      <h2 class="title">Contact</h2>
      <p class="sub">Clique sur n'importe quel item pour jump smooth vers sa section.</p>
    </div>
  </section>

  <section class="fake-section" id="present">
    <div>
      <p class="eyebrow">04 · Présent dans</p>
      <h2 class="title">Présent dans</h2>
      <p class="sub">Le fill marmalade atteint le bas de la track quand tu arrives sur la dernière section.</p>
    </div>
  </section>
</Layout>

<script is:inline>
  (() => {
    const links = Array.from(document.querySelectorAll('.si-link'));
    const sections = links.map((a) => document.getElementById(a.dataset.target)).filter(Boolean);
    const fill = document.querySelector('[data-fill]');
    if (!sections.length || !fill) return;

    const setActive = (activeId) => {
      links.forEach((a) => {
        a.classList.toggle('is-active', a.dataset.target === activeId);
      });
    };

    // Progress fill : basé sur scrollY / (totalHeight - viewport)
    const updateFill = () => {
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const progress = max > 0 ? Math.min(Math.max(window.scrollY / max, 0), 1) : 0;
      fill.style.setProperty('--progress', progress.toFixed(4));
    };

    // Tracking section active via IntersectionObserver
    const observer = new IntersectionObserver(
      (entries) => {
        let bestEntry = null;
        let bestRatio = 0;
        entries.forEach((entry) => {
          if (entry.intersectionRatio > bestRatio) {
            bestRatio = entry.intersectionRatio;
            bestEntry = entry;
          }
        });
        if (bestEntry) {
          setActive(bestEntry.target.id);
        }
      },
      { threshold: [0.25, 0.5, 0.75] }
    );
    sections.forEach((s) => observer.observe(s));

    // Init
    setActive(sections[0].id);
    updateFill();

    // Scroll listener pour le fill (léger, rAF-throttled)
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateFill();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
    window.addEventListener('resize', updateFill, { passive: true });

    // Smooth scroll on click
    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.dataset.target;
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `#${id}`);
      });
    });
  })();
</script>

<style>
  :global(body) { margin: 0; }

  /* ───── Indicateur fixe ───── */
  .scroll-indicator {
    position: fixed;
    left: clamp(24px, 3vw, 44px);
    top: 50%;
    transform: translateY(-50%);
    z-index: 100;
    display: flex;
    align-items: center;
    --dot-col: 10px;
    --gap: 18px;
  }

  /* Track verticale + fill marmalade qui monte avec le scroll */
  .si-track {
    position: absolute;
    left: calc(var(--dot-col) / 2 - 0.5px);
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: var(--rule);
    pointer-events: none;
    overflow: hidden;
  }
  .si-fill {
    --progress: 0;
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    height: calc(var(--progress) * 100%);
    background: var(--marmalade);
    transform-origin: top;
    transition: height 120ms linear;
  }

  .si-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 30px;
    position: relative;
  }

  .si-link {
    display: inline-grid;
    grid-template-columns: var(--dot-col) auto;
    gap: var(--gap);
    align-items: center;
    text-decoration: none;
    color: inherit;
    padding: 2px 0;
  }

  /* ───── Marker (dot + horizontal tick pour l'actif) ───── */
  .si-marker {
    position: relative;
    width: var(--dot-col);
    height: var(--dot-col);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .si-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ink);
    opacity: 0.22;
    transition: width 320ms cubic-bezier(0.34, 1.3, 0.64, 1),
                height 320ms cubic-bezier(0.34, 1.3, 0.64, 1),
                background-color 240ms ease,
                opacity 240ms ease;
  }
  .si-link:hover .si-dot {
    opacity: 0.5;
  }

  /* Tick horizontal — visible uniquement pour l'item actif, pointe vers le label */
  .si-tick {
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left center;
    width: 14px;
    height: 1.5px;
    background: var(--marmalade);
    transition: transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* État actif : dot bigger marmalade + tick déployé */
  .si-link.is-active .si-dot {
    width: 10px;
    height: 10px;
    background: var(--marmalade);
    opacity: 1;
  }
  .si-link.is-active .si-tick {
    transform: translateY(-50%) scaleX(1);
  }

  /* ───── Label ───── */
  .si-label {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
    transition: color 280ms ease, opacity 280ms ease, transform 360ms cubic-bezier(0.22, 1, 0.36, 1);
    white-space: nowrap;
    opacity: 0.6;
  }
  .si-link:hover .si-label {
    opacity: 0.88;
    color: var(--ink);
  }
  .si-link.is-active .si-label {
    opacity: 1;
    color: var(--ink);
    transform: translateX(4px);
  }

  .si-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: -0.02em;
    color: var(--marmalade);
    text-transform: none;
    opacity: 0.7;
    transition: opacity 240ms ease;
  }
  .si-link.is-active .si-num,
  .si-link:hover .si-num {
    opacity: 1;
  }

  /* Name : léger bold shift sur active pour donner du poids */
  .si-name {
    transition: font-weight 280ms ease;
  }
  .si-link.is-active .si-name {
    font-weight: 700;
  }

  /* Masquer sur petit écran */
  @media (max-width: 820px) {
    .scroll-indicator {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .si-dot, .si-tick, .si-label, .si-fill {
      transition: none;
    }
  }

  /* ───── Fake sections (pour démo) ───── */
  .fake-section {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--wrap-pad-x);
    text-align: center;
    border-bottom: 1px solid var(--rule);
  }
  .fake-section:nth-child(odd) { background: var(--paper); }
  .fake-section:nth-child(even) { background: var(--paper-warm); }

  .fake-section .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--marmalade);
    margin: 0;
  }
  .fake-section .title {
    margin: 16px 0 12px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 9vw, 120px);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ink);
  }
  .fake-section .sub {
    margin: 0 auto;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(16px, 1.4vw, 20px);
    color: var(--ink-soft);
    max-width: 48ch;
    line-height: 1.5;
  }
</style>
