---
// Section 10 — Parler (CTA final)
// Contact direct. Explique ce qui se passe après le courriel.

const EMAIL = 'hello@camplo.ca';
const PHONE: string | null = null;
---

<section class="cta-final" id="contact" aria-label="Contact">
  <span class="numeral-bg" aria-hidden="true">IX</span>
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">
        <span class="eyebrow-num">09</span> · Parler
      </p>
      <h2 class="section-title">
        Prêt à remplacer ce qui date de 2008 ?
      </h2>
    </div>

    <div class="body">
      <p>
        Un courriel, un appel. La première conversation est gratuite. On
        vous pose des questions sur votre camping, vous nous posez les
        vôtres. Vingt-cinq minutes en moyenne. Zéro deuxième appel de
        vente pressé.
      </p>
      <p>
        Si après cet appel on pense qu'on peut vous aider, on vous
        envoie un plan écrit par courriel la semaine suivante. Si on
        pense qu'on n'est pas la bonne agence pour vous, on vous le
        dit, et la plupart du temps on vous suggère vers qui aller.
      </p>
    </div>

    <div class="contact-lines">
      <a class="contact-line" href={`mailto:${EMAIL}`}>{EMAIL}</a>
      {
        PHONE && (
          <a class="contact-line" href={`tel:${PHONE.replace(/\s|-/g, '')}`}>
            {PHONE}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--paper-warm);
    padding: var(--section-pad-y) 0 clamp(100px, 14vw, 180px);
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--rule);
  }

  .numeral-bg {
    position: absolute;
    left: -6%;
    top: -14%;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(320px, 48vw, 680px);
    line-height: 0.78;
    color: var(--marmalade);
    opacity: 0.1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .wrap {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  .section-title {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 6vw, 72px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    max-width: 18ch;
  }

  .body {
    margin-top: 28px;
    max-width: 62ch;
    display: grid;
    gap: 20px;
    font-family: var(--font-body);
    font-size: clamp(17px, 1.2vw, 19px);
    line-height: 1.65;
    color: var(--ink-soft);
  }

  .contact-lines {
    margin-top: clamp(48px, 6vw, 80px);
    display: grid;
    gap: clamp(16px, 2vw, 28px);
  }

  .contact-line {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 5vw, 64px);
    letter-spacing: -0.02em;
    color: var(--fern);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 12px;
    transition: color 160ms ease, border-color 160ms ease;
    word-break: break-word;
  }

  .contact-line:hover {
    color: var(--fern-deep);
    border-bottom-color: var(--fern);
  }
</style>
