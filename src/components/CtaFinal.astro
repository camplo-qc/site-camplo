---
// Section 4 — CTA final

const EMAIL = 'hello@camplo.ca';
const PHONE: string | null = null;
---

<section class="cta-final" id="contact" aria-label="Contact">
  <span class="numeral-bg" aria-hidden="true">III</span>
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">
        <span class="eyebrow-num">03</span> · Parler
      </p>
      <h2 class="section-title">Prêt ?</h2>
    </div>

    <p class="lede">
      Un courriel. On répond dans 48h. Si ça match, un appel de 25
      minutes. Pas de deuxième appel de vente pressé.
    </p>

    <div class="contact-lines">
      <a class="contact-line" href={`mailto:${EMAIL}`}>{EMAIL}</a>
      {
        PHONE && (
          <a class="contact-line" href={`tel:${PHONE.replace(/\s|-/g, '')}`}>
            {PHONE}
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--paper-warm);
    padding: var(--section-pad-y) 0;
    border-top: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .numeral-bg {
    position: absolute;
    right: -6%;
    top: -14%;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(320px, 48vw, 680px);
    line-height: 0.78;
    color: var(--marmalade);
    opacity: 0.1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .wrap { position: relative; z-index: 1; }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  .section-title {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 7vw, 96px);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .lede {
    margin-top: 24px;
    max-width: 52ch;
    font-family: var(--font-body);
    font-size: clamp(17px, 1.2vw, 19px);
    line-height: 1.6;
    color: var(--ink-soft);
  }

  .contact-lines {
    margin-top: clamp(40px, 5vw, 72px);
    display: grid;
    gap: clamp(16px, 2vw, 28px);
  }

  .contact-line {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 5vw, 64px);
    letter-spacing: -0.02em;
    color: var(--fern);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 12px;
    transition: color 160ms ease, border-color 160ms ease;
    word-break: break-word;
  }

  .contact-line:hover {
    color: var(--fern-deep);
    border-bottom-color: var(--fern);
  }
</style>
