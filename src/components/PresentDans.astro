---
// Section 4 — Présent dans. Version minimaliste : label centré avec tirets
// marmalade + logo du partenaire + caption "Site + CRM" en dessous.
---

<section id="present-dans" class="present" aria-label="Présent dans">
  <span class="numeral-bg" aria-hidden="true">IV</span>

  <div class="presence">
    <p class="presence-kicker" data-reveal>
      <span class="presence-rule" aria-hidden="true"></span>
      Notre logiciel est présent dans
      <span class="presence-rule" aria-hidden="true"></span>
    </p>

    <div class="presence-logos" data-reveal style="--reveal-delay: 150ms">
      <a
        class="presence-client"
        href="https://delajoiequebec.com"
        target="_blank"
        rel="noopener"
        aria-label="Visiter le site de Camping de la Joie"
      >
        <img src="/partners/delajoie-logo.png" alt="Camping de la Joie — client Camplo, logiciel de gestion camping et site de réservation en ligne" loading="lazy" />
        <span class="presence-cap">Site + CRM</span>
      </a>
    </div>
  </div>
</section>

<style>
  .present {
    background: var(--paper);
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .numeral-bg {
    position: absolute;
    right: -0.04em;
    top: -0.14em;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(280px, 38vw, 500px);
    line-height: 0.78;
    color: var(--fern);
    opacity: 0.06;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .presence {
    position: relative;
    z-index: 1;
    padding: 0 var(--wrap-pad-x);
    text-align: center;
  }

  .presence-kicker {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    margin: 0 0 36px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fern);
  }

  .presence-rule {
    width: clamp(32px, 6vw, 72px);
    height: 1px;
    background: var(--marmalade);
  }

  .presence-logos {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: clamp(32px, 5vw, 64px);
    flex-wrap: wrap;
  }

  .presence-client {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    color: var(--ink);
    transition: transform 380ms cubic-bezier(0.22, 1, 0.36, 1), opacity 240ms ease;
  }
  .presence-client:hover {
    transform: translateY(-2px);
    opacity: 0.88;
  }

  .presence-client img {
    display: block;
    height: clamp(72px, 8vw, 96px);
    width: auto;
  }

  .presence-cap {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .presence-client {
      transition: none;
    }
    .presence-client:hover {
      transform: none;
    }
  }
</style>
