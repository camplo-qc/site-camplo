---
// Section 5 — Présent dans
// Liste des campings clients. Un seul pour l'instant : Camping de la Joie.
---

<section class="present" aria-label="Présent dans">
  <div class="wrap">
    <p class="label">Présent dans</p>
    <div class="clients">
      <a
        href="https://delajoiequebec.com"
        class="client"
        target="_blank"
        rel="noopener"
      >
        Camping de la Joie
        <span class="meta">Laurentides · 162 emplacements</span>
      </a>
      <span class="client placeholder" aria-hidden="true">
        Votre camping
        <span class="meta">Saison 2027</span>
      </span>
      <span class="client placeholder" aria-hidden="true">
        Votre camping
        <span class="meta">Saison 2027</span>
      </span>
    </div>
  </div>
</section>

<style>
  .present {
    background: var(--paper);
    padding: clamp(72px, 9vw, 120px) 0;
    border-top: 1px solid var(--rule);
  }

  .label {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
    text-align: center;
  }

  .clients {
    margin-top: clamp(32px, 4vw, 56px);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  @media (max-width: 720px) {
    .clients { grid-template-columns: 1fr; }
  }

  .client {
    padding: clamp(24px, 3vw, 36px) clamp(16px, 2vw, 28px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 6px;
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(20px, 2.4vw, 30px);
    letter-spacing: -0.01em;
    color: var(--ink);
    border-left: 1px solid var(--rule);
    transition: color 160ms ease, background 160ms ease;
    min-height: 100px;
  }

  .client:first-child { border-left: none; }

  @media (max-width: 720px) {
    .client {
      border-left: none;
      border-top: 1px solid var(--rule);
    }
    .client:first-child { border-top: none; }
  }

  .client:hover:not(.placeholder) {
    color: var(--marmalade);
    background: var(--paper-warm);
  }

  .client .meta {
    font-family: var(--font-label);
    font-weight: 500;
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .client.placeholder {
    color: var(--ink-muted);
    opacity: 0.55;
    cursor: default;
  }

  .client.placeholder .meta {
    color: var(--marmalade);
    opacity: 0.7;
  }
</style>
