---
// Hero v4 — wordmark SVG inline + stagger animation (C → arbre → m p l o → tente)
import fs from 'node:fs';
import path from 'node:path';

const EMAIL = 'adamauger872@gmail.com';
const PHONE = '5817480161';

const svgRaw = fs.readFileSync(
  path.resolve('public/brand/camplo-wordmark.svg'),
  'utf-8'
);

// 1. Wrap chaque lettre (C, m, p, l, o) dans un <g class="cm-letter cm-lN"> externe
//    pour ne pas écraser le transform="translate(x,0) scale(1,-1)" qui positionne
let letterIdx = 0;
let svg = svgRaw.replace(
  /<g transform="translate\([^)]+\) scale\(1,-1\)"><path[^/]+\/><\/g>/g,
  (match) => `<g class="cm-letter cm-l${letterIdx++}">${match}</g>`
);

// 2. Classes sur arbre et tente pour animation séparée
svg = svg
  .replace('<path d="M 29.25 3', '<path class="cm-tree" d="M 29.25 3')
  .replace('<path d="M 29.5 27', '<path class="cm-tent" d="M 29.5 27');

// 3. Restructure : arbre hors de la clipPath, tente + fente beige (paper)
//    wrappés ensemble dans .cm-tent-move pour animer comme une unité.
const DOOR_PATH =
  '<path class="cm-door" d="M 32.5 40 L 33.5 40 L 36 54.5 L 30 54.5 Z" fill="#F6F0E0"/>';
svg = svg.replace(
  /<g clip-path="url\(#door\)">\s*<g transform="translate\(3, 0\)">\s*(<path[^>]*cm-tree[^>]*\/>)\s*(<path[^>]*cm-tent[^>]*\/>)\s*<\/g>\s*<\/g>/,
  (_, tree, tent) =>
    `<g transform="translate(3, 0)">${tree}</g>` +
    `<g class="cm-tent-move">${DOOR_PATH}<g clip-path="url(#door)"><g transform="translate(3, 0)">${tent}</g></g></g>`
);
---

<section class="hero" id="hero" aria-label="Hero">
  <div class="hero-contact" aria-label="Nous contacter">
    <a class="hero-contact-btn" href={`mailto:${EMAIL}`} aria-label="Nous écrire par courriel">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2.5" y="4.5" width="19" height="15" rx="2" />
        <path d="m3 6 9 6 9-6" />
      </svg>
    </a>
    <a class="hero-contact-btn" href={`tel:${PHONE}`} aria-label="Nous appeler par téléphone">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.84.57 2.8.7A2 2 0 0 1 22 16.92z" />
      </svg>
    </a>
  </div>

  <div class="wrap">
    <h1 class="wordmark" aria-label="Camplo">
      <span class="sr-only">Camplo — Logiciel de gestion camping et système de réservation en ligne au Québec</span>
      <div class="wordmark-svg" set:html={svg} aria-hidden="true" />
    </h1>

    <p class="tagline">
      Un logiciel qui <em>opère</em>.<br class="tagline-break" />
      Un site qui <em>encaisse</em>.
    </p>

    <p class="sr-only">
      Camplo est un logiciel de gestion camping (CRM) et un système de réservation en ligne sans commission, conçu au Québec pour les campings indépendants. Application desktop pour vous, site de réservation pour vos campeurs, paiement par carte Stripe intégré, vos données restent chez vous.
    </p>

    <div class="stats" aria-label="Statistiques">
      <div class="stat">
        <span class="stat-num">1</span>
        <span class="stat-label">Camping équipé</span>
      </div>
      <span class="stat-sep" aria-hidden="true"></span>
      <div class="stat">
        <span class="stat-num">162</span>
        <span class="stat-label">Emplacements</span>
      </div>
      <span class="stat-sep" aria-hidden="true"></span>
      <div class="stat">
        <span class="stat-num">0</span>
        <span class="stat-label">Commission</span>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: var(--paper);
    /* Exactement la hauteur du viewport, pas plus. */
    height: 100vh;
    height: 100dvh;
    /* Pull up sous la nav (margin 20px + pill ~52px) pour que le bas du hero
       tombe pile à 100vh, pas à 100vh + nav. Matché en mobile via media. */
    margin-top: -72px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Padding top = zone nav (72px) ; padding bottom = zone stats
       (section-pad-y + ~70px de hauteur des stats) → contenu centré
       visuellement entre la nav et les stats. */
    padding: 72px 0 calc(var(--section-pad-y) + 70px);
    text-align: center;
    box-sizing: border-box;
  }

  @media (max-width: 640px) {
    .hero {
      /* Nav mobile plus petite : margin 14 + pill ~46 = 60px */
      margin-top: -60px;
      padding-top: 60px;
    }
  }

  .wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Icônes contact top-right, alignées verticalement avec la nav pill
     (viewport y=20, height 52px). Pas de fond — juste les icônes stroke. */
  .hero-contact {
    position: absolute;
    top: 20px;
    right: var(--wrap-pad-x);
    z-index: 10;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    height: 52px;
  }
  .hero-contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 9999px;
    color: var(--ink);
    opacity: 0.78;
    transition: opacity 160ms ease, background-color 160ms ease,
                color 160ms ease;
  }
  .hero-contact-btn svg {
    display: block;
    width: 20px;
    height: 20px;
  }
  .hero-contact-btn:hover {
    opacity: 1;
    color: var(--marmalade);
  }

  @media (max-width: 640px) {
    .hero-contact { display: none; }
  }

  .wordmark {
    margin: 0;
    line-height: 0;
    width: 100%;
    max-width: 920px;
    padding: 0 clamp(24px, 5vw, 64px);
  }

  .wordmark-svg {
    display: block;
    width: 100%;
  }

  .wordmark-svg :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  /* Stagger : lettres + arbre invisibles au départ, tente wrapper invisible */
  .wordmark-svg :global(.cm-letter),
  .wordmark-svg :global(.cm-tree),
  .wordmark-svg :global(.cm-tent-move) {
    opacity: 0;
  }
  .wordmark-svg :global(.cm-tent-move) {
    transform-box: fill-box;
    transform-origin: 50% 100%;
  }

  .wordmark-svg :global(.cm-letter),
  .wordmark-svg :global(.cm-tree) {
    animation: cm-letter-in 520ms cubic-bezier(0.2, 0.7, 0.1, 1) both;
  }
  /* Ordre : C — arbre — m — p — l — o — tente */
  .wordmark-svg :global(.cm-l0)   { animation-delay: 120ms; }
  .wordmark-svg :global(.cm-tree) { animation-delay: 240ms; }
  .wordmark-svg :global(.cm-l1)   { animation-delay: 360ms; }
  .wordmark-svg :global(.cm-l2)   { animation-delay: 480ms; }
  .wordmark-svg :global(.cm-l3)   { animation-delay: 600ms; }
  .wordmark-svg :global(.cm-l4)   { animation-delay: 720ms; }

  .wordmark-svg :global(.cm-tent-move) {
    animation: cm-tent-in 820ms cubic-bezier(0.25, 0.8, 0.35, 1) 900ms forwards;
  }

  @keyframes cm-letter-in {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes cm-tent-in {
    0%   { opacity: 0; transform: translateY(22px); animation-timing-function: cubic-bezier(0.3, 0, 0.2, 1); }
    45%  { opacity: 1; }
    55%  { transform: translateY(-4px); animation-timing-function: cubic-bezier(0.33, 0, 0.4, 1); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .tagline {
    margin-top: clamp(24px, 3vw, 40px);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 32px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--ink);
    white-space: nowrap;
    max-width: none;
    opacity: 0;
    animation: cm-letter-in 600ms cubic-bezier(0.2, 0.7, 0.1, 1) 1400ms forwards;
  }

  .tagline em {
    font-style: italic;
    color: var(--marmalade);
  }

  /* Le <br> force 2 lignes uniquement en mobile ; caché sur desktop
     où le nowrap garde tout sur une ligne. */
  .tagline-break {
    display: none;
  }
  @media (max-width: 480px) {
    .tagline {
      white-space: normal;
    }
    .tagline-break {
      display: block;
    }
  }

  /* ───── Stats : 1 camping · 162 empl. · 0 commission.
     Ancrées au bas du hero (absolute bottom). Contraintes latérales
     avec left/right = var(--wrap-pad-x) pour pas toucher les bords. */
  .stats {
    position: absolute;
    left: var(--wrap-pad-x);
    right: var(--wrap-pad-x);
    bottom: var(--section-pad-y);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(20px, 3vw, 40px);
    opacity: 0;
    transform: translateY(14px);
    animation: stats-in 600ms cubic-bezier(0.2, 0.7, 0.1, 1) 1700ms forwards;
  }
  @keyframes stats-in {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }
  .stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 4vw, 52px);
    letter-spacing: -0.02em;
    color: var(--fern);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .stat-sep {
    width: 1px;
    height: 28px;
    background: var(--rule);
  }

  /* Phone uniquement : stats compactes pour rester dans l'écran.
     Tablettes et desktop gardent les tailles clamp() par défaut. */
  @media (max-width: 480px) {
    .stats {
      gap: 10px;
    }
    .stat {
      gap: 4px;
    }
    .stat-num {
      font-size: 20px;
    }
    .stat-label {
      font-size: 8px;
      letter-spacing: 0.08em;
    }
    .stat-sep {
      height: 20px;
    }
  }

  @media (max-width: 360px) {
    .stats {
      gap: 8px;
    }
    .stat-num {
      font-size: 16px;
    }
    .stat-label {
      font-size: 7px;
      letter-spacing: 0.06em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wordmark-svg :global(.cm-letter),
    .wordmark-svg :global(.cm-tree),
    .wordmark-svg :global(.cm-tent-move),
    .tagline {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .stats {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>
