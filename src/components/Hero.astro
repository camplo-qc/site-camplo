---
// Hero v3.1 — wordmark reconstruit en texte + SVG inline (crisp à tout zoom)
---

<section class="hero" aria-label="Hero">
  <div class="wrap">
    <h1 class="wordmark" aria-label="Camplo">
      <span aria-hidden="true">C</span>
      <span class="logomark" aria-hidden="true">
        <svg
          viewBox="0 -5.5 66 66"
          xmlns="http://www.w3.org/2000/svg"
          shape-rendering="geometricPrecision"
        >
          <defs>
            <clipPath id="hero-door-cutout">
              <path
                clip-rule="evenodd"
                fill-rule="evenodd"
                d="M 0 -10 H 66 V 66 H 0 Z M 32.5 40 L 33.5 40 L 36 54.5 L 30 54.5 Z"
              ></path>
            </clipPath>
          </defs>
          <g clip-path="url(#hero-door-cutout)">
            <g transform="translate(3, 0)">
              <path
                d="M 29.25 3 L 30.75 3 L 47.43 19.44 L 47.2 20 L 40 20 L 57.49 41.38 L 57.2 42 L 2.8 42 L 2.51 41.38 L 20 20 L 12.8 20 L 12.57 19.44 Z"
                fill="#3e6b31"
                stroke="#3e6b31"
                stroke-width="3.5"
                stroke-linejoin="miter"
                stroke-miterlimit="4"
              ></path>
              <path
                d="M 29.5 27 L 30.5 27 L 45.60 53.31 L 45.2 54 L 14.8 54 L 14.40 53.31 Z"
                fill="#e8853b"
              ></path>
            </g>
          </g>
        </svg>
      </span>
      <span aria-hidden="true">mplo</span>
    </h1>

    <p class="tagline">
      Un logiciel qui <em>ne date pas</em> de 2008.
    </p>

    <p class="meta">
      <span>Français</span>
      <span>·</span>
      <span>Conçu au Québec</span>
      <span>·</span>
      <span>Depuis 2026</span>
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--paper);
    padding: clamp(80px, 12vw, 160px) 0 clamp(72px, 9vw, 120px);
    text-align: center;
  }

  .wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(80px, 16vw, 240px);
    line-height: 1;
    letter-spacing: -0.035em;
    color: var(--ink);
    margin: 0;
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .logomark {
    display: inline-block;
    width: 0.86em;
    height: 0.86em;
    vertical-align: baseline;
    position: relative;
    top: 0.02em;
    margin: 0 -0.02em;
  }

  .logomark svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .tagline {
    margin-top: clamp(32px, 5vw, 64px);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2.6vw, 36px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--ink-soft);
    max-width: 28ch;
  }

  .tagline em {
    font-style: italic;
    color: var(--marmalade);
  }

  .meta {
    margin-top: clamp(48px, 6vw, 80px);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }
</style>
