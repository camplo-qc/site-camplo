---
// Hero v3 — wordmark intégré (logo à la place du 'a') + tagline
---

<section class="hero" aria-label="Hero">
  <div class="wrap">
    <img
      class="wordmark"
      src="/brand/camplo-wordmark-integrated.png"
      alt="Camplo"
      width="1600"
      height="400"
    />

    <p class="tagline">
      Un logiciel qui <em>ne date pas</em> de 2008.
    </p>

    <p class="meta">
      <span>Français</span>
      <span>·</span>
      <span>Conçu au Québec</span>
      <span>·</span>
      <span>Depuis 2026</span>
    </p>
  </div>
</section>

<style>
  .hero {
    background: var(--paper);
    padding: clamp(80px, 12vw, 160px) 0 clamp(72px, 9vw, 120px);
    text-align: center;
  }

  .wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .wordmark {
    display: block;
    width: clamp(280px, 60vw, 720px);
    height: auto;
    max-width: 100%;
  }

  .tagline {
    margin-top: clamp(32px, 5vw, 64px);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2.6vw, 36px);
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: var(--ink-soft);
    max-width: 28ch;
  }

  .tagline em {
    font-style: italic;
    color: var(--marmalade);
  }

  .meta {
    margin-top: clamp(48px, 6vw, 80px);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-muted);
    letter-spacing: 0.02em;
  }
</style>
