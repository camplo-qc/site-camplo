---
// Section 1 — Produits. Template tabs interactif : un toggle Site|CRM qui
// bascule entre les deux vues du produit avec un fade animé.

const siteFeatures = [
  'Réservation en ligne',
  'Paiement par carte (Stripe)',
  'Confirmation automatique',
  'Aucune commission',
];

const crmFeatures = [
  'Tableau de bord',
  'Calendrier mensuel',
  'Réservations filtrables',
  'Emplacements + services',
  'Clients + historique',
  'Fiscalité TPS/TVQ',
];
---

<section class="ce-quon-fait" id="produits" aria-label="Produits">
  <span class="numeral-bg" aria-hidden="true">I</span>

  <div class="wrap">
    <div class="cqf-head">
      <div class="cqf-heading">
        <p class="eyebrow" data-reveal>
          <span class="eyebrow-num">01</span> · Produits
        </p>
        <h2 class="cqf-title" data-reveal style="--reveal-delay: 100ms">Pour les campings d'ici. <em>Conçu au Québec.</em></h2>
      </div>

      <div class="cqf-tabs" role="tablist" aria-label="Choisir un produit" data-reveal style="--reveal-delay: 200ms">
        <button
          type="button"
          role="tab"
          class="cqf-tab is-active"
          data-target="cqf-site"
          id="cqf-tab-site"
          aria-controls="cqf-site"
          aria-selected="true"
        >
          <span class="cqf-tab-num">01</span>
          <span class="cqf-tab-label">Site</span>
        </button>
        <button
          type="button"
          role="tab"
          class="cqf-tab"
          data-target="cqf-crm"
          id="cqf-tab-crm"
          aria-controls="cqf-crm"
          aria-selected="false"
        >
          <span class="cqf-tab-num">02</span>
          <span class="cqf-tab-label">CRM</span>
        </button>
      </div>
    </div>

    <div class="cqf-stage" data-reveal style="--reveal-delay: 300ms">
      <div
        class="cqf-panel is-active"
        id="cqf-site"
        role="tabpanel"
        aria-labelledby="cqf-tab-site"
      >
        <div class="cqf-copy">
          <p class="cqf-kicker">Pour vos campeurs</p>
          <h3 class="cqf-headline">Ils arrivent, ils réservent, <em>ils paient</em>.</h3>
          <p class="cqf-sub">
            Pas de formulaire de 12 pages, pas d'intermédiaire qui prend
            une commission. Un site qui transforme la curiosité en
            réservation confirmée, paiement encaissé, courriel envoyé.
          </p>
          <ul class="cqf-features">
            {siteFeatures.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="cqf-visual">
          <div class="cqf-visual-placeholder">
            <span class="cqf-visual-label">Aperçu du site public</span>
            <span class="cqf-visual-url">delajoiequebec.com</span>
          </div>
        </div>
      </div>

      <div
        class="cqf-panel"
        id="cqf-crm"
        role="tabpanel"
        aria-labelledby="cqf-tab-crm"
        hidden
      >
        <div class="cqf-copy">
          <p class="cqf-kicker">Pour vous</p>
          <h3 class="cqf-headline">Votre camping, <em>sans le navigateur</em>.</h3>
          <p class="cqf-sub">
            Une app desktop qui tourne localement. Vos données restent
            chez vous. Tout ce qu'il faut pour opérer une saison.
          </p>
          <ul class="cqf-features">
            {crmFeatures.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="cqf-visual">
          <img
            src="/screenshots/crm-dashboard.png"
            alt="CRM Camplo · Tableau de bord"
            loading="lazy"
            width="1445"
            height="900"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const tabs = document.querySelectorAll('.cqf-tab');
    const panels = document.querySelectorAll('.cqf-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-target');
        tabs.forEach((t) => {
          const active = t === tab;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach((p) => {
          const active = p.id === target;
          p.classList.toggle('is-active', active);
          if (active) {
            p.removeAttribute('hidden');
          } else {
            p.setAttribute('hidden', '');
          }
        });
      });
    });
  })();
</script>

<style>
  .ce-quon-fait {
    background: var(--paper-warm);
    padding: var(--section-pad-y) 0;
    border-top: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .numeral-bg {
    position: absolute;
    right: -0.04em;
    top: -0.14em;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(320px, 44vw, 580px);
    line-height: 0.78;
    color: var(--marmalade);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .wrap { position: relative; z-index: 1; }

  /* ───── Head ───── */
  .cqf-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: clamp(24px, 4vw, 48px);
    flex-wrap: wrap;
    margin-bottom: clamp(40px, 5vw, 72px);
  }

  .cqf-heading {
    max-width: 640px;
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  .cqf-title {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: -0.025em;
    line-height: 1;
    color: var(--ink);
  }
  .cqf-title em {
    font-style: italic;
    font-weight: 500;
    color: var(--fern);
  }

  /* ───── Tabs ───── */
  .cqf-tabs {
    display: inline-flex;
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: 9999px;
    padding: 4px;
    gap: 2px;
    align-self: center;
  }

  .cqf-tab {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: transparent;
    border: none;
    border-radius: 9999px;
    cursor: pointer;
    transition: background-color 240ms ease, color 240ms ease;
  }
  .cqf-tab:hover:not(.is-active) {
    color: var(--ink);
  }

  .cqf-tab-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    color: var(--marmalade);
  }
  .cqf-tab.is-active {
    background: var(--ink);
    color: var(--paper);
  }
  .cqf-tab.is-active .cqf-tab-num {
    color: var(--marmalade);
  }

  /* ───── Stage & panels ───── */
  .cqf-stage {
    position: relative;
  }
  .cqf-panel {
    display: none;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
    animation: cqf-fade 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cqf-panel.is-active {
    display: grid;
  }
  @keyframes cqf-fade {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cqf-kicker {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }

  .cqf-headline {
    margin: 14px 0 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(30px, 3.6vw, 48px);
    letter-spacing: -0.02em;
    line-height: 1.08;
    color: var(--ink);
  }
  .cqf-headline em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }

  .cqf-sub {
    margin-top: 18px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.1vw, 17px);
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 44ch;
  }

  .cqf-features {
    list-style: none;
    margin: clamp(24px, 3vw, 32px) 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
    grid-template-columns: 1fr 1fr;
  }
  .cqf-features li {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .cqf-features li::before {
    content: '';
    width: 8px;
    height: 1px;
    background: var(--marmalade);
    flex-shrink: 0;
  }

  .cqf-visual {
    border: 1px solid var(--rule);
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background: var(--paper);
  }
  .cqf-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cqf-visual-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: repeating-linear-gradient(
      45deg,
      var(--paper),
      var(--paper) 12px,
      var(--paper-warm) 12px,
      var(--paper-warm) 24px
    );
  }
  .cqf-visual-label {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--ink-muted);
    font-size: clamp(16px, 1.5vw, 20px);
  }
  .cqf-visual-url {
    font-family: var(--font-label);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--marmalade);
  }

  @media (max-width: 860px) {
    .cqf-head {
      flex-direction: column;
      align-items: flex-start;
    }
    .cqf-tabs {
      align-self: flex-start;
    }
    .cqf-panel.is-active {
      grid-template-columns: 1fr;
    }
    .cqf-features {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cqf-panel,
    .cqf-tab {
      animation: none;
      transition: none;
    }
  }
</style>
