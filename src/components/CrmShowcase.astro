---
// Section 4 — Le logiciel de gestion
// Version éventail : toutes les photos en fan, texte des features en dessous.

const shots = [
  {
    src: '/screenshots/crm-dashboard.png',
    alt: 'Tableau de bord du logiciel Camplo',
    label: 'Tableau de bord',
  },
  {
    src: '/screenshots/crm-calendrier.png',
    alt: 'Calendrier mensuel avec une ligne par emplacement',
    label: 'Calendrier',
  },
  {
    src: '/screenshots/crm-reservations.png',
    alt: 'Liste des réservations avec statuts et prix',
    label: 'Réservations',
  },
  {
    src: '/screenshots/crm-emplacements.png',
    alt: 'Liste des emplacements avec dimensions et véhicules',
    label: 'Emplacements',
  },
  {
    src: '/screenshots/crm-clients.png',
    alt: 'Liste des clients avec coordonnées',
    label: 'Clients',
  },
  {
    src: '/screenshots/crm-fiscal.png',
    alt: 'Page fiscalité avec revenus mensuels',
    label: 'Fiscalité',
  },
];
---

<section class="crm" aria-label="Le logiciel de gestion">
  <span class="numeral-bg" aria-hidden="true">III</span>

  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">
        <span class="eyebrow-num">03</span> · Le logiciel de gestion
      </p>
      <h2 class="section-title">Ce que l'accueil ouvre le matin à 8h.</h2>
    </div>

    <div class="intro">
      <p>
        Le logiciel est une vraie app desktop pour Mac ou Windows. Pas
        un site web, pas un outil qui rame sur le wifi du terrain. Un
        programme qui s'installe, qui ouvre avec un raccourci sur le
        bureau, qui continue de fonctionner quand internet tombe en
        plein samedi après-midi.
      </p>
    </div>
  </div>

  <div class="fan-wrap">
    <div class="fan" role="list">
      {
        shots.map((shot, i) => (
          <figure class="fan-card" role="listitem" style={`--i: ${i}`}>
            <img
              src={shot.src}
              alt={shot.alt}
              loading="lazy"
              width="1450"
              height="900"
            />
            <figcaption>{shot.label}</figcaption>
          </figure>
        ))
      }
    </div>
  </div>

  <div class="wrap">
    <dl class="features-list">
      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">I.</span> Tableau de bord
        </dt>
        <dd>
          Le matin à 8h : qui arrive, qui part, qui doit encore payer.
          Un bouton <em>Imprimer la liste du jour</em> sort un PDF
          qu'on scotche à côté du téléphone.
        </dd>
      </div>

      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">II.</span> Calendrier
        </dt>
        <dd>
          Vue mensuelle, une ligne par emplacement, une cellule par
          jour. Vert pâle pour les nuits réservées. On voit les
          chevauchements, les trous, les saisonniers qui courent tout
          l'été sur le même numéro.
        </dd>
      </div>

      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">III.</span> Réservations
        </dt>
        <dd>
          Toutes les réservations filtrables par statut (confirmée, en
          attente, annulée, complétée, no-show). Création en quelques
          clics, carte de crédit effacée le jour de l'arrivée, note
          optionnelle.
        </dd>
      </div>

      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">IV.</span> Emplacements
        </dt>
        <dd>
          Chaque emplacement a son numéro, son service (3 services 50A,
          30A, Nature, Chalet), ses dimensions en pieds, ses véhicules
          acceptés. 162 emplacements chez Camping de la Joie, tous
          catalogués.
        </dd>
      </div>

      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">V.</span> Clients
        </dt>
        <dd>
          Nom, courriel, téléphone, ville, historique. Pas de
          newsletter forcée, pas de segmentation marketing, pas de
          scoring. Juste ce qu'il faut pour savoir à qui on parle.
        </dd>
      </div>

      <div class="feature-item">
        <dt>
          <span class="marker" aria-hidden="true">VI.</span> Fiscalité
        </dt>
        <dd>
          Revenus du mois, taux d'occupation, revenu moyen par nuit.
          Graphique annuel, remplissage par type de service. TPS 5% et
          TVQ 9.975% calculées. Bouton <em>Exporter PDF</em> pour la
          comptable.
        </dd>
      </div>
    </dl>

    <div class="under-hood">
      <h3 class="under-title">Sous le capot</h3>
      <ul>
        <li>Multi-utilisateur avec deux niveaux de rôle (standard et super-admin)</li>
        <li>Données stockées localement en SQLite, sur votre ordinateur</li>
        <li>Fonctionne hors-ligne, se synchronise quand la connexion revient</li>
        <li>Construit avec Tauri, Vue 3, TypeScript. Léger, rapide, audité</li>
        <li>Mises à jour automatiques par le réseau, sans que personne ait à courir après</li>
      </ul>
    </div>
  </div>
</section>

<style>
  .crm {
    background: var(--paper);
    padding: var(--section-pad-y) 0 clamp(60px, 8vw, 100px);
    border-top: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }

  .numeral-bg {
    position: absolute;
    right: -4%;
    top: -8%;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(280px, 42vw, 560px);
    line-height: 0.78;
    color: var(--marmalade);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .wrap {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  .section-title {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 64px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    max-width: 20ch;
  }

  .intro {
    margin-top: clamp(32px, 4vw, 56px);
    max-width: 60ch;
    font-family: var(--font-body);
    font-size: clamp(17px, 1.2vw, 19px);
    line-height: 1.65;
    color: var(--ink-soft);
  }

  /* ÉVENTAIL — fan des screenshots */
  .fan-wrap {
    position: relative;
    z-index: 2;
    margin: clamp(72px, 9vw, 120px) 0;
    padding: 0 var(--wrap-pad-x);
    overflow: visible;
  }

  .fan {
    position: relative;
    height: clamp(360px, 44vw, 620px);
    max-width: var(--wrap-max);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .fan-card {
    position: absolute;
    width: clamp(280px, 36vw, 580px);
    aspect-ratio: 1450 / 900;
    margin: 0;
    border-radius: 8px;
    border: 1px solid var(--rule);
    box-shadow: 0 12px 40px rgba(28, 28, 26, 0.18), 0 2px 8px rgba(28, 28, 26, 0.08);
    background: var(--paper-warm);
    overflow: hidden;
    transition: transform 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
                box-shadow 320ms ease;
    transform-origin: 50% 110%;
    --step: 10deg;
    --offset: 9%;
  }

  /* Fan layout: 6 cards, indices 0 to 5
     centered around middle-ish, rotated and horizontally offset */
  .fan-card:nth-child(1) { transform: rotate(calc(var(--step) * -2.5)) translateX(calc(var(--offset) * -2.5)); z-index: 1; }
  .fan-card:nth-child(2) { transform: rotate(calc(var(--step) * -1.5)) translateX(calc(var(--offset) * -1.5)); z-index: 2; }
  .fan-card:nth-child(3) { transform: rotate(calc(var(--step) * -0.5)) translateX(calc(var(--offset) * -0.5)); z-index: 3; }
  .fan-card:nth-child(4) { transform: rotate(calc(var(--step) *  0.5)) translateX(calc(var(--offset) *  0.5)); z-index: 4; }
  .fan-card:nth-child(5) { transform: rotate(calc(var(--step) *  1.5)) translateX(calc(var(--offset) *  1.5)); z-index: 5; }
  .fan-card:nth-child(6) { transform: rotate(calc(var(--step) *  2.5)) translateX(calc(var(--offset) *  2.5)); z-index: 6; }

  .fan-card:hover,
  .fan-card:focus-within {
    transform: rotate(0deg) translateX(0) translateY(-16px) scale(1.05);
    z-index: 20;
    box-shadow: 0 24px 60px rgba(28, 28, 26, 0.28), 0 4px 12px rgba(28, 28, 26, 0.1);
  }

  .fan-card img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  .fan-card figcaption {
    position: absolute;
    bottom: 10px;
    left: 12px;
    right: 12px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--paper);
    background: rgba(28, 28, 26, 0.78);
    backdrop-filter: blur(6px);
    padding: 8px 10px;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 200ms ease;
    text-align: center;
  }

  .fan-card:hover figcaption,
  .fan-card:focus-within figcaption {
    opacity: 1;
  }

  /* Mobile : fallback en stack vertical */
  @media (max-width: 720px) {
    .fan {
      height: auto;
      flex-direction: column;
      gap: 16px;
    }
    .fan-card,
    .fan-card:nth-child(1),
    .fan-card:nth-child(2),
    .fan-card:nth-child(3),
    .fan-card:nth-child(4),
    .fan-card:nth-child(5),
    .fan-card:nth-child(6) {
      position: static;
      width: 100%;
      transform: none;
    }
    .fan-card:nth-child(even) {
      transform: rotate(-1.5deg);
    }
    .fan-card:nth-child(odd) {
      transform: rotate(1.5deg);
    }
    .fan-card figcaption {
      opacity: 1;
    }
  }

  /* Liste des features */
  .features-list {
    margin-top: clamp(48px, 7vw, 96px);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(32px, 4vw, 56px) clamp(48px, 5vw, 80px);
  }

  @media (max-width: 720px) {
    .features-list {
      grid-template-columns: 1fr;
    }
  }

  .feature-item {
    padding-top: 20px;
    border-top: 1px solid var(--rule);
  }

  .feature-item dt {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(22px, 2.2vw, 28px);
    letter-spacing: -0.01em;
    line-height: 1.2;
    color: var(--ink);
  }

  .marker {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    margin-right: 6px;
    font-size: 0.82em;
  }

  .feature-item dd {
    margin-top: 12px;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 44ch;
  }

  .feature-item dd em {
    font-style: italic;
    color: var(--ink);
  }

  /* Under the hood */
  .under-hood {
    padding: clamp(48px, 6vw, 80px) 0 0;
    margin-top: clamp(48px, 6vw, 80px);
    border-top: 1px solid var(--rule);
  }
  .under-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: -0.01em;
    line-height: 1.1;
    color: var(--ink);
  }
  .under-hood ul {
    margin-top: 20px;
    display: grid;
    gap: 12px;
    list-style: none;
    max-width: 62ch;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .under-hood li {
    padding-left: 22px;
    position: relative;
  }
  .under-hood li::before {
    content: '·';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--marmalade);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    line-height: 1;
  }
</style>
