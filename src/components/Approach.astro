---
// Section 4 — Approche
// Background: paper. 3 principes en grille I/II/III.
---

<section class="approach" id="approche" aria-label="Approche">
  <span class="numeral-bg" aria-hidden="true">III</span>
  <div class="wrap">
    <div class="section-head">
      <p class="eyebrow">
        <span class="eyebrow-num">03</span> · Approche
      </p>
      <h2 class="section-title">Trois choses qui changent tout.</h2>
    </div>

    <ol class="principles">
      <li class="principle principle-left">
        <span class="num" aria-hidden="true">I</span>
        <div class="body">
          <h3 class="title">
            Sur mesure. Pour un seul camping : le vôtre.
          </h3>
          <p class="desc">
            Pas une template partagée entre des milliers de sites. Votre
            outil est conçu pour votre réalité — votre carte, vos types
            d'emplacements, votre façon de faire.
          </p>
        </div>
      </li>

      <li class="principle principle-center">
        <span class="num" aria-hidden="true">II</span>
        <h3 class="title title-big">
          On parle <em>camping</em>, en français.
        </h3>
        <p class="desc">
          Terrains saisonniers, emplacements 50 ampères, sites de passage,
          chalets 4 saisons. On sait le vocabulaire avant la première
          réunion.
        </p>
      </li>

      <li class="principle principle-right">
        <div class="body">
          <h3 class="title">Vos données restent chez vous.</h3>
          <p class="desc">
            Le logiciel vit sur votre ordinateur. Vos données restent au
            Québec. Votre camping fonctionne même quand internet est
            coupé.
          </p>
        </div>
        <span class="num" aria-hidden="true">III</span>
      </li>
    </ol>
  </div>
</section>

<style>
  .approach {
    background: var(--paper);
    padding: var(--section-pad-y) 0;
    position: relative;
    overflow: hidden;
  }

  .numeral-bg {
    position: absolute;
    right: -4%;
    top: -8%;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(280px, 42vw, 560px);
    line-height: 0.78;
    color: var(--marmalade);
    opacity: 0.08;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }

  .wrap {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
  }
  .eyebrow-num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
    text-transform: none;
    letter-spacing: 0;
    font-size: 14px;
    margin-right: 2px;
  }

  .section-title {
    margin-top: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(32px, 5vw, 56px);
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  .principles {
    list-style: none;
    margin-top: clamp(48px, 6vw, 80px);
    display: grid;
    gap: 0;
  }

  .principle {
    padding: clamp(40px, 5vw, 72px) 0;
    border-top: 1px solid var(--rule);
  }

  .principle:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .num {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(40px, 5vw, 64px);
    color: var(--marmalade);
    line-height: 1;
    display: block;
  }

  .body {
    max-width: 62ch;
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--ink);
  }

  .desc {
    margin-top: 16px;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-soft);
  }

  /* I — aligned left, numeral top */
  .principle-left {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: clamp(24px, 4vw, 48px);
  }

  /* II — center, massive pull-quote feel */
  .principle-center {
    text-align: center;
    padding: clamp(56px, 7vw, 96px) 0;
  }
  .principle-center .num {
    margin: 0 auto 24px;
  }
  .principle-center .title-big {
    font-size: clamp(36px, 5vw, 64px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    max-width: 18ch;
    margin: 0 auto;
  }
  .principle-center .title-big em {
    font-style: italic;
    color: var(--marmalade);
  }
  .principle-center .desc {
    max-width: 52ch;
    margin: 20px auto 0;
  }

  /* III — aligned right, numeral right */
  .principle-right {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 120px;
    gap: clamp(24px, 4vw, 48px);
    text-align: right;
  }
  .principle-right .body {
    margin-left: auto;
  }
  .principle-right .num {
    text-align: left;
  }

  @media (max-width: 640px) {
    .principle-left,
    .principle-right {
      grid-template-columns: 1fr;
      gap: 12px;
      text-align: left;
    }
    .principle-right .num {
      text-align: left;
    }
    .num {
      font-size: 40px;
    }
    .principle-center .title-big {
      font-size: 32px;
    }
  }
</style>
