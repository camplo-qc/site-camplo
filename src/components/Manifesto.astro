---
// Manifeste — rupture entre Services et CaseStudy
// Une seule phrase massive en italique. Pas d'eyebrow, pas de CTA, pas de numéro.
---

<section class="manifesto" aria-label="Manifeste">
  <div class="wrap">
    <p class="phrase">
      Un camping à la fois. <br aria-hidden="true" />
      Parce que deux, déjà, <span class="accent">c'est un de trop</span>.
    </p>
  </div>
</section>

<style>
  .manifesto {
    background: var(--paper);
    padding: clamp(140px, 20vw, 240px) 0;
    text-align: left;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .phrase {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(40px, 7vw, 104px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--ink);
    max-width: 20ch;
  }

  .phrase .accent {
    color: var(--marmalade);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .phrase br {
      display: none;
    }
  }
</style>
